@model SCM_System.Models.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body p-4 p-sm-5">
        <div class="text-center mb-4">
            <h3 class="mt-2 fw-bold">Quên mật khẩu</h3>
            <p class="text-muted">Nhập tên đăng nhập để tìm tài khoản của bạn</p>
        </div>

        <form asp-action="ForgotPassword" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger py-2">
                    <div asp-validation-summary="All" class="mb-0"></div>
                </div>
            }

            <div class="form-floating mb-4">
                <input asp-for="Username" type="text" class="form-control" id="usernameInput" placeholder="Tên đăng nhập" />
                <label for="usernameInput">Tên đăng nhập</label>
                <span asp-validation-for="Username" class="text-danger small"></span>
            </div>

            <div class="d-grid mb-3">
                <button class="btn btn-primary btn-lg" type="submit">Tìm tài khoản</button>
            </div>

            <div class="text-center">
                <a href="@Url.Action("Login", "Account")" class="text-decoration-none">← Quay lại đăng nhập</a>
            </div>
        </form>
    </div>
</div>
