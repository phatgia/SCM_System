@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Views/Shared/_AuthLayout.cshtml"; // Gọi Layout riêng
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body p-4 p-sm-5">
        <div class="text-center mb-4">
            <h3 class="mt-2 fw-bold">Đăng nhập</h3>
            <p class="text-muted">Vui lòng đăng nhập để tiếp tục</p>
        </div>

        <form>
            <div class="form-floating mb-3">
                <input type="email" class="form-control" id="emailInput" placeholder="name@example.com" required>
                <label for="emailInput">Địa chỉ Email</label>
            </div>
            
            <div class="form-floating mb-4">
                <input type="password" class="form-control" id="passwordInput" placeholder="Password" required>
                <label for="passwordInput">Mật khẩu</label>
            </div>

            <div class="text-end mb-4">
                <a href="@Url.Action("ForgotPassword", "Account")" class="text-decoration-none text-danger fw-bold">Quên mật khẩu?</a>
            </div>

            <div class="d-grid mb-3">
                <button class="btn btn-primary btn-lg" type="submit">Đăng nhập</button>
            </div>

            <div class="text-center">
                <span class="text-muted">Chưa có tài khoản?</span>
                <a href="@Url.Action("Register", "Account")" class="text-decoration-none fw-bold">Đăng ký ngay</a>
            </div>
        </form>
    </div>
</div>