@model SCM_System.Models.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body p-4 p-sm-5">
        <div class="text-center mb-4">
            <h3 class="mt-2 fw-bold">Đặt lại mật khẩu</h3>
            <p class="text-muted">Tài khoản: <strong>@Model.Username</strong></p>
        </div>

        <form asp-action="ResetPassword" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Username" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger py-2">
                    <div asp-validation-summary="ModelOnly" class="mb-0"></div>
                </div>
            }

            <div class="form-floating mb-3">
                <input asp-for="NewPassword" type="password" class="form-control" id="newPasswordInput" placeholder="Mật khẩu mới" />
                <label for="newPasswordInput">Mật khẩu mới</label>
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-4">
                <input asp-for="ConfirmPassword" type="password" class="form-control" id="confirmPasswordInput" placeholder="Xác nhận mật khẩu" />
                <label for="confirmPasswordInput">Xác nhận mật khẩu mới</label>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <div class="d-grid mb-3">
                <button class="btn btn-success btn-lg" type="submit">Xác nhận đặt lại</button>
            </div>

            <div class="text-center">
                <a href="@Url.Action("ForgotPassword", "Account")" class="text-decoration-none">← Nhập lại tên đăng nhập</a>
            </div>
        </form>
    </div>
</div>
