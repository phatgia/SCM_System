@model SCM_System.Models.ViewModels.AdminCombinedViewModel
@{
    ViewData["Title"] = "Quản trị hệ thống";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-1">Quản trị hệ thống</h4>
        <p class="text-muted small mb-0">Quản lý tài khoản, phân quyền, cấu hình và báo cáo</p>
    </div>
</div>

<ul class="nav nav-tabs mb-4">
    <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#menu1"><i class="bi bi-person-vcard me-1"></i>Tài khoản & Phân quyền</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#menu2"><i class="bi bi-sliders me-1"></i>Cấu hình hệ thống</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#menu3"><i class="bi bi-bar-chart-line me-1"></i>Báo cáo tổng quan</a></li>
</ul>

<div class="tab-content">
    
    <div class="tab-pane active" id="menu1">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="d-flex gap-2">
                <input type="text" class="form-control form-control-sm" style="width:250px;" placeholder="Tìm theo tên, email...">
                <select class="form-select form-select-sm" style="width:180px;">
                    <option>Tất cả vai trò</option>
                    @foreach (var role in Model.UserVM.Roles)
                    {
                        <option>@role.RoleName</option>
                    }
                </select>
            </div>
            <a href="/Account/Register" class="btn btn-sm btn-primary shadow-sm">
                <i class="bi bi-person-plus me-1"></i> Thêm tài khoản
            </a>
        </div>

        <div class="card border-0 shadow-sm overflow-hidden">
            <div class="table-responsive">
                <table class="table align-middle mb-0 table-hover">
                    <thead class="bg-light">
                        <tr class="text-muted small">
                            <th class="ps-4 py-3">NHÂN VIÊN</th>
                            <th class="py-3">TÊN ĐĂNG NHẬP</th>
                            <th class="py-3">VAI TRÒ</th>
                            <th class="py-3">LIÊN HỆ</th>
                            <th class="py-3">TRẠNG THÁI</th>
                            <th class="text-end pe-4 py-3">THAO TÁC</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model.UserVM.Users)
                        {
                            <tr class="border-top">
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-bold shadow-sm" style="width:38px;height:38px;font-size: 0.85rem;">
                                            @u.FullName.Substring(0, Math.Min(2, u.FullName.Length)).ToUpper()
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@u.FullName</div>
                                            <div class="text-muted small" style="font-size: 0.75rem;">ID: #@u.UserID.ToString("D3")</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-muted small fw-semibold">@u.Username</td>
                                <td>
                                    @if (u.RoleName == "Quản trị viên") { <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger px-3 py-1">@u.RoleName</span> }
                                    else if (u.RoleName == "Quản lý kho") { <span class="badge rounded-pill bg-success bg-opacity-10 text-success px-3 py-1">@u.RoleName</span> }
                                    else { <span class="badge rounded-pill bg-info bg-opacity-10 text-info px-3 py-1">@u.RoleName</span> }
                                </td>
                                <td class="text-muted small">@u.Email</td>
                                <td>
                                    @if (u.Status == "Chờ duyệt") { <span class="badge rounded-pill bg-warning bg-opacity-10 text-warning px-3 py-1"><i class="bi bi-clock-history me-1"></i> @u.Status</span> }
                                    else { <span class="badge rounded-pill bg-success bg-opacity-10 text-success px-3 py-1"><i class="bi bi-check-circle me-1"></i> @u.Status</span> }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        @if (u.Status == "Chờ duyệt")
                                        {
                                            <form asp-action="ApproveUser" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@u.UserID" />
                                                <button type="submit" class="btn btn-sm btn-outline-success me-1" title="Duyệt tài khoản"><i class="bi bi-check-lg"></i></button>
                                            </form>
                                        }
                                        <button class="btn btn-sm btn-light border text-primary me-1 btn-edit-user" data-id="@u.UserID" title="Chỉnh sửa"><i class="bi bi-pencil-square"></i></button>
                                        <button class="btn btn-sm btn-light border text-danger btn-delete-user" data-id="@u.UserID" data-name="@u.FullName" title="Xóa"><i class="bi bi-trash3"></i></button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        
        <div class="card border-0 shadow-sm mt-4 overflow-hidden">
            <div class="p-3 border-bottom bg-light d-flex align-items-center justify-content-between">
                <h6 class="mb-0 fw-bold"><i class="bi bi-shield-check me-2"></i>Ma trận phân quyền hệ thống</h6>
                <span class="badge bg-white text-muted border fw-normal">Xem trước thiết lập</span>
            </div>
            <div class="table-responsive">
                <table class="table align-middle mb-0 table-sm">
                    <thead class="bg-light">
                        <tr class="text-muted small"><th class="ps-4">CHỨC NĂNG</th><th class="text-center">Quản trị viên</th><th class="text-center">Mua hàng</th><th class="text-center">Quản lý kho</th><th class="text-center">Vận chuyển</th><th class="text-center">Bán hàng</th></tr>
                    </thead>
                    <tbody class="small">
                        <tr><td class="ps-4">Quản lý NCC & Đơn nhập</td><td class="text-center text-success"><i class="bi bi-check-lg"></i></td><td class="text-center text-success"><i class="bi bi-check-lg"></i></td><td></td><td></td><td></td></tr>
                        <tr><td class="ps-4">Quản lý Kho & Tồn kho</td><td class="text-center text-success"><i class="bi bi-check-lg"></i></td><td></td><td class="text-center text-success"><i class="bi bi-check-lg"></i></td><td></td><td></td></tr>
                        <tr><td class="ps-4">Quản lý Đơn bán & Đổi trả</td><td class="text-center text-success"><i class="bi bi-check-lg"></i></td><td></td><td></td><td></td><td class="text-center text-success"><i class="bi bi-check-lg"></i></td></tr>
                        <tr><td class="ps-4">Điều phối Vận chuyển</td><td class="text-center text-success"><i class="bi bi-check-lg"></i></td><td></td><td></td><td class="text-center text-success"><i class="bi bi-check-lg"></i></td><td></td></tr>
                        <tr><td class="ps-4">Quản trị Hệ thống</td><td class="text-center text-success"><i class="bi bi-check-lg"></i></td><td></td><td></td><td></td><td></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="tab-pane" id="menu2">
        <div class="container" style="max-width:800px;">
            <form asp-action="SaveConfig" method="post">
                @Html.AntiForgeryToken()
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-3"><i class="bi bi-box-seam me-2 text-primary"></i>Cài đặt kho hàng</h6>
                        <div class="row g-3">
                            <div class="col-md-12">
                                <label class="form-label small fw-semibold">Ngưỡng tồn kho thấp</label>
                                <input type="number" asp-for="ConfigVM.LowStockThreshold" class="form-control shadow-sm" placeholder="VD: 5">
                                <div class="form-text small">Hệ thống sẽ cảnh báo khi số lượng dưới mức này.</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-3"><i class="bi bi-bell me-2 text-warning"></i>Thông báo & Hệ thống</h6>
                        <div class="row mb-4">
                            <div class="col-md-12">
                                <div class="form-check form-switch mb-3">
                                    <input class="form-check-input" type="checkbox" asp-for="ConfigVM.AutoBackup" id="swBackup">
                                    <label class="form-check-label ms-2" for="swBackup">Sao lưu dữ liệu tự động hằng ngày</label>
                                </div>
                                <div class="form-check form-switch mb-3">
                                    <input class="form-check-input" type="checkbox" asp-for="ConfigVM.EnableEmail" id="swEmail">
                                    <label class="form-check-label ms-2" for="swEmail">Gửi Email thông báo đơn hàng</label>
                                </div>
                                <div class="form-check form-switch mb-3">
                                    <input class="form-check-input" type="checkbox" asp-for="ConfigVM.EnableSMS" id="swSms">
                                    <label class="form-check-label ms-2" for="swSms">Gửi SMS cho mã xác thực PIN</label>
                                </div>
                            </div>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold">Đơn vị tiền tệ</label>
                                <select asp-for="ConfigVM.Currency" class="form-select shadow-sm">
                                    <option value="VND">VND (vnđ)</option>
                                    <option value="USD">USD ($)</option>
                                    <option value="EUR">EUR (€)</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold">Múi giờ hệ thống</label>
                                <select asp-for="ConfigVM.TimeZone" class="form-select shadow-sm">
                                    <option value="Asia/Ho_Chi_Minh">Asia/Ho_Chi_Minh (GMT+7)</option>
                                    <option value="UTC">UTC (Universal Time)</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mb-5">
                    <button type="reset" class="btn btn-light border px-4">Khôi phục</button>
                    <button type="submit" class="btn btn-primary px-4 shadow"><i class="bi bi-save me-1"></i> Lưu cấu hình</button>
                </div>
            </form>
        </div>
    </div>

    <div class="tab-pane" id="menu3">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-3">
                <form asp-action="Reports" method="get">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-3">
                            <label class="form-label small fw-semibold">Loại báo cáo</label>
                            <select name="reportType" class="form-select form-select-sm shadow-sm">
                                <option value="summary" selected="@(Model.ReportVM.ReportType == "summary")">Tổng quan thu chi</option>
                                <option value="revenue" selected="@(Model.ReportVM.ReportType == "revenue")">Biểu đồ doanh thu</option>
                                <option value="purchase" selected="@(Model.ReportVM.ReportType == "purchase")">Biểu đồ nhập hàng</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-semibold">Từ ngày</label>
                            <input type="date" name="fromDate" class="form-control form-control-sm shadow-sm">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-semibold">Đến ngày</label>
                            <input type="date" name="toDate" class="form-control form-control-sm shadow-sm">
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-sm btn-primary px-4 shadow-sm"><i class="bi bi-filter me-1"></i>Xem báo cáo</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-3"><div class="card border-0 shadow-sm bg-primary bg-opacity-10 h-100"><div class="card-body"><p class="small text-primary fw-semibold mb-1">TỔNG DOANH THU</p><h3 class="fw-bold mb-0">@Model.ReportVM.CurrencySymbol@Model.ReportVM.TotalRevenue</h3></div></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm bg-danger bg-opacity-10 h-100"><div class="card-body"><p class="small text-danger fw-semibold mb-1">CHI PHÍ NHẬP HÀNG</p><h3 class="fw-bold mb-0">@Model.ReportVM.CurrencySymbol@Model.ReportVM.TotalExpense</h3></div></div></div>
            <div class="col-md-2"><div class="card border-0 shadow-sm h-100"><div class="card-body text-center"><p class="small text-muted fw-semibold mb-1">ĐƠN HOÀN THÀNH</p><h3 class="fw-bold mb-0">@Model.ReportVM.CompletedOrdersCount</h3></div></div></div>
            <div class="col-md-2"><div class="card border-0 shadow-sm h-100"><div class="card-body text-center"><p class="small text-muted fw-semibold mb-1">TỶ LỆ GIAO HÀNG</p><h3 class="fw-bold mb-0 text-success">@Model.ReportVM.DeliverySuccessRate</h3></div></div></div>
            <div class="col-md-2"><div class="card border-0 shadow-sm h-100"><div class="card-body text-center"><p class="small text-muted fw-semibold mb-1">TỶ LỆ ĐỔI TRẢ</p><h3 class="fw-bold mb-0 text-warning">@Model.ReportVM.ReturnRate</h3></div></div></div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold mb-0">Biểu đồ biến động</h5>
                        <span class="badge bg-light text-dark border fw-normal">Đơn vị: @Model.ReportVM.CurrencySymbol</span>
                    </div>
                    <div class="card-body px-4 pb-4">
                        <div style="height: 400px; position: relative;">
                            <canvas id="mainChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white p-4">
                <h5 class="modal-title fw-bold"><i class="bi bi-pencil-square me-2"></i>Chỉnh sửa tài khoản</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="UpdateUser" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" id="editUserId" />
                <div class="modal-body p-4">
                    <div class="mb-3"><label class="form-label small fw-bold">Họ và tên</label><input type="text" name="fullName" id="editFullName" class="form-control" required></div>
                    <div class="mb-3"><label class="form-label small fw-bold">Tên đăng nhập (<span id="displayUsername" class="text-primary"></span>)</label><input type="text" class="form-control bg-light" id="editUsername" readonly disabled></div>
                    <div class="mb-3"><label class="form-label small fw-bold">Email</label><input type="email" name="email" id="editEmail" class="form-control" required></div>
                    <div class="mb-3"><label class="form-label small fw-bold">SĐT</label><input type="text" name="phone" id="editPhone" class="form-control"></div>
                    <div class="mb-0">
                        <label class="form-label small fw-bold">Vai trò / Phân quyền</label>
                        <select name="roleId" id="editRoleId" class="form-select shadow-sm" required>
                            @foreach (var role in Model.UserVM.Roles)
                            {
                                <option value="@role.RoleID">@role.RoleName</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer p-4 border-0">
                    <button type="button" class="btn btn-light border px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary px-4 shadow-sm"><i class="bi bi-save me-1"></i> Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteUserModal" tabindex="-1">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-body p-4 text-center">
                <div class="display-4 text-danger mb-3"><i class="bi bi-exclamation-octagon"></i></div>
                <h5 class="fw-bold">Xác nhận xóa?</h5>
                <p class="text-muted small">Bạn có chắc chắn muốn xóa tài khoản <span id="deleteUserName" class="fw-bold text-dark"></span>?</p>
                <form asp-action="DeleteUser" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="userId" id="deleteUserId" />
                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-danger">Xóa tài khoản</button>
                        <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Hủy bỏ</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // 1. CƠ CHẾ CHUYỂN TAB TỰ ĐỘNG & ĐỒNG BỘ LAYOUT (Giống trang Vận Chuyển)
        function forceSwitchTab() {
            let hash = window.location.hash || "#menu1";
            let tabLink = document.querySelector('.nav-tabs a[href="' + hash + '"]');
            if (tabLink) {
                let tab = new bootstrap.Tab(tabLink);
                tab.show();
            }
        }
        
        document.addEventListener("DOMContentLoaded", function () {
            forceSwitchTab();
            window.addEventListener('hashchange', forceSwitchTab);

            let tabElements = document.querySelectorAll('.nav-tabs a[data-bs-toggle="tab"]');
            tabElements.forEach(function(el) {
                el.addEventListener('shown.bs.tab', function (e) {
                    let currentHash = e.target.getAttribute('href');
                    history.replaceState(null, null, currentHash); 
                    window.dispatchEvent(new Event('hashchange')); 
                });
            });
        });

        // 2. LOGIC TÀI KHOẢN (Modals)
        $(document).ready(function () {
            $('.btn-edit-user').on('click', function () {
                const id = $(this).data('id');
                $.get('/Admin/GetUser/' + id, function (data) {
                    $('#editUserId').val(data.userId);
                    $('#editFullName').val(data.fullName);
                    $('#editUsername').val(data.username);
                    $('#displayUsername').text(data.username);
                    $('#editEmail').val(data.email);
                    $('#editPhone').val(data.phone);
                    $('#editRoleId').val(data.roleId);
                    $('#editUserModal').modal('show');
                }).fail(function() { alert('Không thể tải thông tin người dùng.'); });
            });

            $('.btn-delete-user').on('click', function () {
                $('#deleteUserId').val($(this).data('id'));
                $('#deleteUserName').text($(this).data('name'));
                $('#deleteUserModal').modal('show');
            });
        });

        // 3. LOGIC BIỂU ĐỒ CHART.JS
        let myChart = null;
        function initChart() {
            if (myChart) return; // Nếu đã vẽ rồi thì không vẽ lại

            const ctx = document.getElementById('mainChart');
            if(!ctx) return;

            const reportType = '@Model.ReportVM.ReportType';
            const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ReportVM.ChartLabels));
            const revData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ReportVM.ChartDataRevenue));
            const expData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ReportVM.ChartDataExpense));
            const symbol = '@Model.ReportVM.CurrencySymbol';

            let datasets = [];
            if (reportType === 'summary') {
                datasets = [
                    { label: 'Doanh thu (Sales)', data: revData, borderColor: '#0d6efd', backgroundColor: 'rgba(13, 110, 253, 0.1)', borderWidth: 3, fill: true, tension: 0.4, yAxisID: 'y' },
                    { label: 'Chi phí (Purchases)', data: expData, borderColor: '#dc3545', backgroundColor: 'rgba(220, 53, 69, 0.1)', borderWidth: 3, fill: true, tension: 0.4, yAxisID: 'y1' }
                ];
            } else if (reportType === 'revenue') {
                datasets = [{ label: 'Doanh thu bán hàng', data: revData, borderColor: '#0d6efd', backgroundColor: 'rgba(13, 110, 253, 0.1)', borderWidth: 3, fill: true, tension: 0.4, yAxisID: 'y' }];
            } else {
                datasets = [{ label: 'Chi phí nhập hàng', data: expData, borderColor: '#dc3545', backgroundColor: 'rgba(220, 53, 69, 0.1)', borderWidth: 3, fill: true, tension: 0.4, yAxisID: 'y' }];
            }

            myChart = new Chart(ctx.getContext('2d'), {
                type: 'line',
                data: { labels: labels, datasets: datasets },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: { tooltip: { callbacks: { label: function(context) { return (context.dataset.label ? context.dataset.label + ': ' : '') + symbol + context.parsed.y.toLocaleString('vi-VN'); } } } },
                    scales: { y: { beginAtZero: true }, y1: { display: (reportType === 'summary'), position: 'right', beginAtZero: true, grid: { drawOnChartArea: false } }, x: { grid: { display: false } } }
                }
            });
        }

        // Kích hoạt vẽ biểu đồ khi người dùng click sang Tab Báo Cáo
        $('a[data-bs-toggle="tab"]').on('shown.bs.tab', function (e) {
            if ($(e.target).attr('href') === '#menu3') {
                initChart();
            }
        });

        // Nếu load trang mà hash đang ở sẵn tab Báo Cáo, vẽ luôn
        if(window.location.hash === '#menu3') {
            initChart();
        }
    </script>
}