@model SCM_System.Models.ViewModels.AdminReportViewModel
@{
    ViewData["Title"] = "Quản trị hệ thống - Báo cáo";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-1">Quản trị hệ thống</h4>
        <p class="text-muted small mb-0">Quản lý tài khoản, phân quyền, cấu hình và báo cáo</p>
    </div>
</div>

<ul class="nav nav-tabs mb-4">
    <li class="nav-item"><a class="nav-link" asp-action="Users"><i class="bi bi-person-vcard me-1"></i>Tài khoản & Phân quyền</a></li>
    <li class="nav-item"><a class="nav-link" asp-action="Config"><i class="bi bi-sliders me-1"></i>Cấu hình hệ thống</a></li>
    <li class="nav-item"><a class="nav-link active" asp-action="Reports"><i class="bi bi-bar-chart-line me-1"></i>Báo cáo tổng quan</a></li>
</ul>

<div class="tab-content">
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-3">
            <form asp-action="Reports" method="get">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Loại báo cáo</label>
                        <select name="reportType" class="form-select form-select-sm shadow-sm">
                            <option value="summary" selected="@(Model.ReportType == "summary")">Tổng quan thu chi</option>
                            <option value="revenue" selected="@(Model.ReportType == "revenue")">Biểu đồ doanh thu</option>
                            <option value="purchase" selected="@(Model.ReportType == "purchase")">Biểu đồ nhập hàng</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Từ ngày</label>
                        <input type="date" name="fromDate" class="form-control form-control-sm shadow-sm">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Đến ngày</label>
                        <input type="date" name="toDate" class="form-control form-control-sm shadow-sm">
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-sm btn-primary px-4 shadow-sm"><i class="bi bi-filter me-1"></i>Xem báo cáo</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-primary bg-opacity-10 h-100">
                <div class="card-body">
                    <p class="small text-primary fw-semibold mb-1">TỔNG DOANH THU</p>
                    <h3 class="fw-bold mb-0">@Model.CurrencySymbol@Model.TotalRevenue</h3>
                    <p class="small text-muted mb-0 mt-2"><i class="bi bi-graph-up-arrow text-success me-1"></i>Đã quy đổi tỷ giá</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-danger bg-opacity-10 h-100">
                <div class="card-body">
                    <p class="small text-danger fw-semibold mb-1">CHI PHÍ NHẬP HÀNG</p>
                    <h3 class="fw-bold mb-0">@Model.CurrencySymbol@Model.TotalExpense</h3>
                    <p class="small text-muted mb-0 mt-2"><i class="bi bi-cash-stack text-danger me-1"></i>Dựa trên đơn hoàn thành</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <p class="small text-muted fw-semibold mb-1">ĐƠN HOÀN THÀNH</p>
                    <h3 class="fw-bold mb-0">@Model.CompletedOrdersCount</h3>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <p class="small text-muted fw-semibold mb-1">TỶ LỆ GIAO HÀNG</p>
                    <h3 class="fw-bold mb-0 text-success">@Model.DeliverySuccessRate</h3>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <p class="small text-muted fw-semibold mb-1">TỶ LỆ ĐỔI TRẢ</p>
                    <h3 class="fw-bold mb-0 text-warning">@Model.ReturnRate</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0">Biểu đồ biến động (@(Model.ReportType == "summary" ? "Tổng quan" : (Model.ReportType == "revenue" ? "Doanh thu" : "Chi phí")))</h5>
                    <span class="badge bg-light text-dark border fw-normal">Đơn vị: @Model.CurrencySymbol</span>
                </div>
                <div class="card-body px-4 pb-4">
                    <div style="height: 400px; position: relative;">
                        <canvas id="mainChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const ctx = document.getElementById('mainChart').getContext('2d');
            const reportType = '@Model.ReportType';
            const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartLabels));
            const revData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartDataRevenue));
            const expData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartDataExpense));
            const symbol = '@Model.CurrencySymbol';

            console.log("Report Type:", reportType);

            let datasets = [];

            if (reportType === 'summary') {
                datasets = [
                    {
                        label: 'Doanh thu (Sales)',
                        data: revData,
                        borderColor: '#0d6efd',
                        backgroundColor: 'rgba(13, 110, 253, 0.1)',
                        borderWidth: 3,
                        fill: true,
                        tension: 0.4,
                        yAxisID: 'y'
                    },
                    {
                        label: 'Chi phí (Purchases)',
                        data: expData,
                        borderColor: '#dc3545',
                        backgroundColor: 'rgba(220, 53, 69, 0.1)',
                        borderWidth: 3,
                        fill: true,
                        tension: 0.4,
                        yAxisID: 'y1'
                    }
                ];
            } else if (reportType === 'revenue') {
                datasets = [{
                    label: 'Doanh thu bán hàng',
                    data: revData,
                    borderColor: '#0d6efd',
                    backgroundColor: 'rgba(13, 110, 253, 0.1)',
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4,
                    yAxisID: 'y'
                }];
            } else {
                datasets = [{
                    label: 'Chi phí nhập hàng',
                    data: expData,
                    borderColor: '#dc3545',
                    backgroundColor: 'rgba(220, 53, 69, 0.1)',
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4,
                    yAxisID: 'y'
                }];
            }

            new Chart(ctx, {
                type: 'line',
                data: { labels: labels, datasets: datasets },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        legend: { 
                            display: true,
                            position: 'top',
                            labels: { usePointStyle: true, padding: 20 }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    let label = context.dataset.label || '';
                                    if (label) label += ': ';
                                    label += symbol + context.parsed.y.toLocaleString('vi-VN');
                                    return label;
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            type: 'linear',
                            display: true,
                            position: 'left',
                            title: { display: true, text: 'Doanh thu' },
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    if (symbol === '₫' && value >= 1000000) return (value / 1000000).toFixed(0) + ' Tr';
                                    return value.toLocaleString('vi-VN');
                                }
                            }
                        },
                        y1: {
                            type: 'linear',
                            display: (reportType === 'summary'),
                            position: 'right',
                            title: { display: true, text: 'Chi phí' },
                            beginAtZero: true,
                            grid: { drawOnChartArea: false },
                            ticks: {
                                callback: function(value) {
                                    if (symbol === '₫' && value >= 1000000) return (value / 1000000).toFixed(0) + ' Tr';
                                    return value.toLocaleString('vi-VN');
                                }
                            }
                        },
                        x: { grid: { display: false } }
                    }
                }
            });
        });
    </script>
}
