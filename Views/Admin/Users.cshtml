<script>
document.querySelectorAll(".toggle-permission").forEach(btn => {
    btn.addEventListener("click", function () {
        let enabled = this.getAttribute("data-enabled") === "true";

        if (enabled) {
            this.innerHTML = '<i class="bi bi-x-lg text-muted"></i>';
            this.setAttribute("data-enabled", "false");
        } else {
            this.innerHTML = '<i class="bi bi-check-lg text-success"></i>';
            this.setAttribute("data-enabled", "true");
        }
    });
});
</script>