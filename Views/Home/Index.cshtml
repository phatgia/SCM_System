@model SCM_System.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Tổng quan";
    string format = ViewBag.Format ?? "N0";
}

<div class="container-fluid py-4 bg-light">
    <div class="row align-items-center mb-4">
        <div class="col">
            <h2 class="fw-bold mb-0 text-dark">Tổng quan hệ thống</h2>
            <p class="text-muted small mb-0">Theo dõi hoạt động kinh doanh và vận hành thời gian thực</p>
        </div>
    </div>

    <!-- STATS CARDS -->
    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-white">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-primary bg-opacity-10 p-3 rounded-3 text-primary me-3">
                            <i class="bi bi-graph-up-arrow fs-4"></i>
                        </div>
                        <div>
                            <p class="text-secondary small fw-bold text-uppercase mb-1">Doanh thu @Model.MonthLabel</p>
                            <h4 class="fw-bold mb-0">@Model.MonthlyRevenue.ToString(format) @Model.CurrencySymbol</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-white">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-success bg-opacity-10 p-3 rounded-3 text-success me-3">
                            <i class="bi bi-cart3 fs-4"></i>
                        </div>
                        <div>
                            <p class="text-secondary small fw-bold text-uppercase mb-1">Đơn hàng mới</p>
                            <h4 class="fw-bold mb-0">@Model.TotalOrders</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-white">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-warning bg-opacity-10 p-3 rounded-3 text-warning me-3">
                            <i class="bi bi-box fs-4"></i>
                        </div>
                        <div>
                            <p class="text-secondary small fw-bold text-uppercase mb-1">Giá trị tồn kho</p>
                            <h4 class="fw-bold mb-0">@Model.InventoryValue.ToString(format) @Model.CurrencySymbol</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-white">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-info bg-opacity-10 p-3 rounded-3 text-info me-3">
                            <i class="bi bi-truck fs-4"></i>
                        </div>
                        <div>
                            <p class="text-secondary small fw-bold text-uppercase mb-1">Đang vận chuyển</p>
                            <h4 class="fw-bold mb-0">@Model.ActiveDeliveriesCount</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- CHARTS (Line & Donut) -->
    <div class="row g-4 mb-4">
        <div class="col-xl-8">
            <div class="card border-0 shadow-sm rounded-4 bg-white h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between mb-4">
                        <div>
                            <h5 class="fw-bold mb-1">Biến động Doanh thu & Chi phí</h5>
                            <p class="text-muted small mb-0">Dữ liệu 6 tháng gần nhất (triệu @Model.CurrencySymbol)</p>
                        </div>
                    </div>
                    <div style="height: 350px;">
                        <canvas id="revenueCostChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="card border-0 shadow-sm rounded-4 bg-white h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-1">Trạng thái đơn hàng</h5>
                    <p class="text-muted small mb-4">Phân bổ trong @Model.MonthLabel</p>
                    <div style="height: 250px;" class="mb-4">
                        <canvas id="orderStatusChart"></canvas>
                    </div>
                    <div class="mt-4 pt-2">
                        @for (int i = 0; i < Model.OrderStatusLabels.Count; i++)
                        {
                            var colors = new[] { "#10b981", "#3b82f6", "#f59e0b", "#6366f1", "#ef4444" };
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div class="d-flex align-items-center">
                                    <span class="rounded-circle me-3" style="width: 10px; height: 10px; background-color: @colors[i % colors.Length];"></span>
                                    <span class="text-secondary small fw-medium">@Model.OrderStatusLabels[i]</span>
                                </div>
                                <span class="fw-bold small">@Model.OrderStatusCounts[i]</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- RECENT ORDERS & WARNINGS -->
    <div class="row g-4 mb-4">
        <div class="col-xl-8">
            <div class="card border-0 shadow-sm rounded-4 bg-white">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between mb-4">
                        <h5 class="fw-bold mb-0">Đơn hàng gần đây</h5>
                        <a href="/Sales/Orders" class="btn btn-sm btn-link text-decoration-none fw-bold">Xem tất cả <i class="bi bi-arrow-right"></i></a>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="bg-light text-muted small fw-bold">
                                <tr>
                                    <th>MÃ ĐƠN</th>
                                    <th>KHÁCH HÀNG</th>
                                    <th class="text-end">TỔNG TIỀN</th>
                                    <th>TRẠNG THÁI</th>
                                    <th>NGÀY</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model.RecentOrders)
                                {
                                    <tr>
                                        <td class="fw-bold py-3">@order.OrderCode</td>
                                        <td class="small">@order.CustomerName</td>
                                        <td class="text-end fw-bold">@order.TotalAmount.ToString(format) @Model.CurrencySymbol</td>
                                        <td>
                                            @{
                                                var badgeClass = order.Status switch {
                                                    "Hoàn thành" => "bg-success",
                                                    "Đang giao hàng" => "bg-primary",
                                                    "Đã hủy" => "bg-danger",
                                                    _ => "bg-warning"
                                                };
                                            }
                                            <span class="badge @badgeClass bg-opacity-10 text-@badgeClass.Replace("bg-", "") px-3 rounded-pill">@order.Status</span>
                                        </td>
                                        <td class="text-muted small">@order.Date.ToString("dd/MM/yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="card border-0 shadow-sm rounded-4 bg-white mb-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>
                        <h6 class="fw-bold mb-0">Cảnh báo tồn kho thấp</h6>
                    </div>
                    <div class="list-group list-group-flush">
                        @if (!Model.LowStockWarnings.Any()) {
                            <p class="text-muted small py-3 mb-0">Tồn kho hiện tại ở mức an toàn.</p>
                        }
                        @foreach (var alert in Model.LowStockWarnings)
                        {
                            <div class="list-group-item px-0 py-3 border-0 border-bottom border-light">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-bold mb-0 text-dark">@alert.ProductName</div>
                                        <small class="text-muted">@alert.CategoryName</small>
                                    </div>
                                    <div class="text-end">
                                        <div class="text-danger fw-bold">@alert.CurrentStock</div>
                                        <small class="text-muted">Min: @alert.Threshold</small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 bg-white">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-clock-history text-primary me-2"></i>
                        <h6 class="fw-bold mb-0">Hoạt động vận chuyển</h6>
                    </div>
                    @if (!Model.ActiveDeliveries.Any()) {
                        <p class="text-muted small py-3 mb-0">Hiện không có đơn hàng đang giao.</p>
                    }
                    @foreach (var delivery in Model.ActiveDeliveries)
                    {
                        <div class="mb-4 last-child-mb-0">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-bold small text-primary">@delivery.OrderCode</span>
                                <span class="badge bg-primary bg-opacity-10 text-primary small px-2">Đang giao</span>
                            </div>
                            <div class="small text-dark fw-medium">@delivery.CustomerName</div>
                            <div class="text-muted x-small">Tài xế: @delivery.ShipperName</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- INVENTORY BY CATEGORY -->
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 bg-white">
                <div class="card-body p-5">
                    <h5 class="fw-bold mb-1">Cơ cấu tồn kho theo danh mục</h5>
                    <p class="text-muted small mb-4">Tổng số lượng sản phẩm hiện có</p>
                    <div style="height: 350px;">
                        <canvas id="inventoryCategoryChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Line Chart: Revenue & Cost
            const ctxLine = document.getElementById('revenueCostChart').getContext('2d');
            new Chart(ctxLine, {
                type: 'line',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.MonthlyLabels)),
                    datasets: [
                        {
                            label: 'Doanh thu',
                            data: @Html.Raw(Json.Serialize(Model.MonthlyRevenues)),
                            borderColor: '#3b82f6',
                            backgroundColor: 'rgba(59, 130, 246, 0.1)',
                            borderWidth: 3,
                            tension: 0.4,
                            fill: true,
                            pointRadius: 4,
                            pointBackgroundColor: '#fff',
                            pointBorderColor: '#3b82f6'
                        },
                        {
                            label: 'Chi phí (Nhập hàng)',
                            data: @Html.Raw(Json.Serialize(Model.MonthlyCosts)),
                            borderColor: '#10b981',
                            backgroundColor: 'rgba(16, 185, 129, 0.05)',
                            borderWidth: 3,
                            tension: 0.4,
                            fill: true,
                            pointRadius: 4,
                            pointBackgroundColor: '#fff',
                            pointBorderColor: '#10b981'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top', align: 'end', labels: { boxWidth: 12, usePointStyle: true, font: { size: 12 } } },
                        tooltip: { backgroundColor: '#1e293b', titleFont: { size: 14 }, bodyFont: { size: 13 }, padding: 12 }
                    },
                    scales: {
                        x: { grid: { display: false } },
                        y: { 
                            beginAtZero: true,
                            grid: { color: '#f1f5f9', borderDash: [5, 5] },
                            ticks: { callback: value => value + 'M' }
                        }
                    }
                }
            });

            // Donut Chart: Order Status
            const ctxDonut = document.getElementById('orderStatusChart').getContext('2d');
            new Chart(ctxDonut, {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.OrderStatusLabels)),
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(Model.OrderStatusCounts)),
                        backgroundColor: ['#10b981', '#3b82f6', '#f59e0b', '#6366f1', '#ef4444'],
                        borderWidth: 5,
                        borderColor: '#ffffff',
                        hoverOffset: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '75%',
                    plugins: {
                        legend: { display: false },
                        tooltip: { backgroundColor: '#1e293b' }
                    }
                }
            });

            // Bar Chart: Inventory Category
            const ctxBar = document.getElementById('inventoryCategoryChart').getContext('2d');
            new Chart(ctxBar, {
                type: 'bar',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.InventoryCategoryLabels)),
                    datasets: [{
                        label: 'Số lượng hàng',
                        data: @Html.Raw(Json.Serialize(Model.InventoryCategoryQuantities)),
                        backgroundColor: '#6366f1',
                        borderRadius: 8,
                        barThickness: 50
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: { backgroundColor: '#1e293b' }
                    },
                    scales: {
                        x: { grid: { display: false } },
                        y: { 
                            beginAtZero: true, 
                            grid: { color: '#f1f5f9' },
                            ticks: { stepSize: 50 }
                        }
                    }
                }
            });
        });
    </script>
}
