                <p class="text-muted small mb-4">Số lượng hiện tại</p>
                
                <div style="height: 300px; width: 100%;">
                    <canvas id="inventoryCategoryChart"></canvas>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const ctxLine = document.getElementById('revenueCostChart').getContext('2d');
            new Chart(ctxLine, {
                type: 'line',
                data: {
                    labels: ['T10/25', 'T11/25', 'T12/25', 'T1/26', 'T2/26', 'T3/26'],
                    datasets: [
                        {
                            label: 'Doanh thu',
                            data: [610, 720, 980, 710, 680, 890],
                            borderColor: '#3b82f6', // Màu xanh dương
                            borderWidth: 2,
                            tension: 0.4, // Uốn cong đường kẻ
                            pointRadius: 0, // Ẩn điểm tròn
                            pointHoverRadius: 6
                        },
                        {
                            label: 'Chi phí',
                            data: [510, 620, 810, 590, 560, 740],
                            borderColor: '#10b981', // Màu xanh lá
                            borderWidth: 2,
                            tension: 0.4,
                            pointRadius: 0,
                            pointHoverRadius: 6
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { color: '#f3f4f6', drawBorder: false } },
                        y: {
                            min: 0, max: 1000,
                            ticks: {
                                stepSize: 250,
                                callback: function(value) { return value + 'M'; }
                            },
                            grid: { color: '#f3f4f6', borderDash: [5, 5], drawBorder: false }
                        }
                    }
                }
            });

            const ctxDonut = document.getElementById('orderStatusChart').getContext('2d');
            new Chart(ctxDonut, {
                type: 'doughnut',
                data: {
                    labels: ['Đã giao', 'Đang giao', 'Đang xử lý', 'Mới tạo', 'Đã hủy'],
                    datasets: [{
                        data: [89, 12, 28, 15, 12], // Số liệu thực tế
                        backgroundColor: [
                            '#10b981', // Xanh lá
                            '#3b82f6', // Xanh dương
                            '#f59e0b', // Cam
                            '#6366f1', // Tím
                            '#ef4444'  // Đỏ
                        ],
                        borderWidth: 3, // Độ dày của viền trắng giữa các miếng
                        borderColor: '#ffffff', // Viền trắng
                        hoverOffset: 4 // Hiệu ứng đẩy miếng bánh ra ngoài khi rê chuột
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%', // Bí kíp: Đục lỗ ở giữa to ra (70%) để thành Donut mảnh
                    plugins: {
                        legend: { 
                            display: false // Ẩn chú thích gốc vì mình đã tự code HTML ở trên
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    let label = context.label || '';
                                    if (label) { label += ': '; }
                                    if (context.parsed !== null) {
                                        label += context.parsed + ' đơn'; // Nối thêm chữ "đơn" vào tooltip
                                    }
                                    return label;
                                }
                            }
                        }
                    }
                }
            });
            
            const ctxBar = document.getElementById('inventoryCategoryChart').getContext('2d');
            new Chart(ctxBar, {
                type: 'bar', // Chỉ định loại biểu đồ cột
                data: {
                    labels: ['CPU', 'GPU', 'RAM', 'SSD', 'Bo mạch', 'Phụ kiện'],
                    datasets: [{
                        label: 'Số lượng',
                        data: [42, 22, 96, 96, 15, 165], // Dữ liệu giả lập theo ảnh
                        backgroundColor: [
                            '#2563eb', // Xanh dương (CPU)
                            '#8b5cf6', // Tím (GPU)
                            '#16a34a', // Xanh lá (RAM)
                            '#0ea5e9', // Xanh ngọc (SSD)
                            '#d97706', // Cam (Bo mạch)
                            '#6b7280'  // Xám (Phụ kiện)
                        ],
                        borderRadius: 4, // BÍ KÍP 1: Bo tròn 4px ở đỉnh cột cho mềm mại
                        borderSkipped: false, // Giữ bo góc cân đối
                        barThickness: 60 // Độ rộng (mập) của mỗi cột, có thể tăng giảm tùy ý
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false // Ẩn chú thích (Legend) vì trục X đã có tên rồi
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return ' ' + context.parsed.y + ' cái';
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            grid: {
                                display: false, // BÍ KÍP 2: Ẩn các đường kẻ lưới dọc cho giao diện thoáng hơn
                                drawBorder: false
                            }
                        },
                        y: {
                            min: 0,
                            max: 180, // Set max 180 để cột cao nhất (165) không đụng nóc
                            ticks: {
                                stepSize: 40 // Bước nhảy của trục Y (0, 40, 80, 120, 160)
                            },
                            grid: {
                                color: '#f3f4f6',
                                borderDash: [5, 5], // Kẻ đường gạch đứt
                                drawBorder: false
                            }
                        }
                    }
                }
            });
                
        });
    </script>
}
