@model SCM_System.Models.ViewModels.SupplierPageViewModel
@{
    ViewData["Title"] = "Mua hàng & NCC";
}

<div class="container-fluid" style="padding:20px 20px">
    <div class="row">
        <h1>Mua hàng & Nhà cung cấp</h1>
    </div>

    <div class="row mt-4">
        <ul class="nav nav-tabs">
            <li class="nav-item">
                <a class="nav-link active" data-bs-toggle="tab" href="#menu1">Nhà cung cấp</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#menu2">Đơn nhập hàng</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#menu3">Tạo đơn nhập</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#menu4">Trả hàng NCC</a>
            </li>
        </ul>
    </div>

    <div class="row">
        <div class="tab-content">

            @* ========== TAB 1: NHÀ CUNG CẤP ========== *@
            <div class="tab-pane container active" id="menu1">

                <div class="mt-4">
                    @* Search + Add Button *@
                    <form asp-action="Supplier" asp-controller="Purchase" method="get" class="d-flex gap-2">
                        <input type="text" name="search" value="@Model.SearchTerm"
                               class="w-50 rounded p-2 border border-secondary"
                               placeholder="Tìm nhà cung cấp...">
                        <button type="submit" class="btn btn-outline-secondary">
                            <i class="bi bi-search"></i> Tìm
                        </button>
                        @if (!string.IsNullOrEmpty(Model.SearchTerm))
                        {
                            <a asp-action="Supplier" asp-controller="Purchase" class="btn btn-outline-secondary">
                                <i class="bi bi-x"></i> Xóa lọc
                            </a>
                        }
                        <button type="button" class="rounded bg-primary text-white p-2 ps-3 pe-3 border-0 ms-auto"
                                data-bs-toggle="modal" data-bs-target="#addSupplierModal">
                            <i class="bi bi-plus"></i> Thêm nhà cung cấp
                        </button>
                    </form>
                </div>

                <div class="mt-4">
                    @if (!Model.Suppliers.Any())
                    {
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-buildings fs-1"></i>
                            <p class="mt-2">Chưa có nhà cung cấp nào. Hãy thêm mới!</p>
                        </div>
                    }
                    else
                    {
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Mã NCC</th>
                                    <th>TÊN NHÀ CUNG CẤP</th>
                                    <th>LIÊN HỆ</th>
                                    <th>EMAIL</th>
                                    <th>SỐ ĐƠN</th>
                                    <th>TỔNG ĐÃ MUA</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in Model.Suppliers)
                                {
                                    <tr>
                                        <td class="border-bottom-0">NCC@(s.SupplierID.ToString("D3"))</td>
                                        <td class="d-flex flex-column border-bottom-0">
                                            @s.SupplierName
                                            @if (!string.IsNullOrEmpty(s.Address))
                                            {
                                                <span class="small text-secondary">@s.Address</span>
                                            }
                                        </td>
                                        <td class="d-flex flex-column border-bottom-0">
                                            @s.ContactPerson
                                            @if (!string.IsNullOrEmpty(s.Phone))
                                            {
                                                <span class="small text-secondary">@s.Phone</span>
                                            }
                                        </td>
                                        <td class="border-bottom-0">@(s.Email ?? "—")</td>
                                        <td class="border-bottom-0">@s.TotalOrders</td>
                                        <td class="border-bottom-0">@s.TotalPurchased.ToString("N0") ₫</td>
                                        <td class="border-bottom-0">
                                            @* Edit Button *@
                                            <button class="border-0 bg-transparent"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#editSupplierModal"
                                                    data-id="@s.SupplierID"
                                                    data-name="@s.SupplierName"
                                                    data-contact="@s.ContactPerson"
                                                    data-phone="@s.Phone"
                                                    data-email="@s.Email"
                                                    data-address="@s.Address"
                                                    title="Chỉnh sửa">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>

                                            @* Delete Button *@
                                            <form asp-action="DeleteSupplier" asp-controller="Purchase"
                                                  method="post" class="d-inline"
                                                  onsubmit="return confirm('Xác nhận xóa nhà cung cấp \'@s.SupplierName\'?')">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@s.SupplierID" />
                                                <button type="submit" class="border-0 bg-transparent text-danger" title="Xóa">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>

            <div class="tab-pane container" id="menu2">
                <div class="mt-4">
                    <form action="">
                        <input type="text" name="" id="" class="w-50 rounded p-2 border border-secondary" placeholder="Tìm đơn nhập...">
                        <button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown">
                            Tất cả trạng thái
                        </button>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="#">Tất cả trạng thái</a></li>
                            <li><a class="dropdown-item" href="#">Bản nháp</a></li>
                            <li><a class="dropdown-item" href="#">Chờ duyệt</a></li>
                            <li><a class="dropdown-item" href="#">Đã duyệt</a></li>
                            <li><a class="dropdown-item" href="#">Đang vận chuyển</a></li>
                            <li><a class="dropdown-item" href="#">Hoàn thành</a></li>
                            <li><a class="dropdown-item" href="#">Đã hủy</a></li>
                        </ul>

                    </form>
                </div>

                <div class="mt-4">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Mã ĐƠN</th>
                                <th>Tên NHÀ CUNG CẤP</th>
                                <th>NGÀY ĐẶT</th>
                                <th>NGÀY GIAO HÀNG DỰ KIẾN</th>
                                <th>GIÁ TRỊ</th>
                                <th>TRẠNG THÁI</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr >
                                <td class="border-bottom-0">PO-2026-001</td>
                                <td class=" border-bottom-0">
                                    TechCore Distribution
                                </td>
                                <td class=" border-bottom-0">2026-03-15</td>
                                <td class=" border-bottom-0">
                                    2026-03-22	
                                </td>
                                <td class=" border-bottom-0">   
                                    185.000.000 ₫
                                </td>
                                <td class=" border-bottom-0 d-flex items-center justify-content-center"><span class="badge bg-success rounded-pill px-3 py-2">Hoàn thành</span></td>
                                <td class=" border-bottom-0">
                                    <button class="border-0 bg-white">
                                        <i class="bi bi-eye"></i>
                                    </button>

                                </td>
                            </tr>

                            <tr >
                                <td class="border-bottom-0">PO-2026-001</td>
                                <td class=" border-bottom-0">
                                    TechCore Distribution
                                </td>
                                <td class=" border-bottom-0">2026-03-15</td>
                                <td class=" border-bottom-0">
                                    2026-03-22	
                                </td>
                                <td class=" border-bottom-0">   
                                    185.000.000 ₫
                                </td>
                                <td class=" border-bottom-0 d-flex items-center justify-content-center"><span class="badge bg-primary rounded-pill px-3 py-2">Đang vận chuyển</span></td>
                                <td class=" border-bottom-0">
                                    <button class="border-0 bg-white">
                                        <i class="bi bi-eye"></i>
                                    </button>

                                </td>
                            </tr>


                            <tr >
                                <td class="border-bottom-0">PO-2026-001</td>
                                <td class=" border-bottom-0">
                                    TechCore Distribution
                                </td>
                                <td class=" border-bottom-0">2026-03-15</td>
                                <td class=" border-bottom-0">
                                    2026-03-22	
                                </td>
                                <td class=" border-bottom-0">   
                                    185.000.000 ₫
                                </td>
                                <td class=" border-bottom-0 d-flex items-center justify-content-center"><span class="badge bg-danger rounded-pill px-3 py-2">Đã hủy</span></td>
                                <td class=" border-bottom-0">
                                    <button class="border-0 bg-white">
                                        <i class="bi bi-eye"></i>
                                    </button>

                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="tab-pane container" id="menu3">
                <form class="mt-4" action="">
                    <div class="container">
                        <div class="row border border-secondary rounded">
                            <div class="mb-3 mt-3">
                                <label for="supplier" class="form-label">Nhà cung cấp *</label>
                                <select name="" class="form-select" id="">
                                    <option selected>--Chọn nhà cung cấp--</option>
                                    <option value="1">TechCore Distribution</option>
                                    <option value="2">CPU VietNam Co.</option>
                                    <option value="3">RAM & Storage Hub</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label for="date" class="form-label">Ngày giao hàng dự kiến</label>
                                <input type="date" class="form-control" id="date" placeholder="mm/dd/yyy" name="date">
                            </div>
                            <div class="mb-3">
                                <label for="comment">Ghi chú</label>
                                <textarea class="form-control" rows="2" id="comment" name="text" placeholder="Ghi chú đặc biệt..."></textarea>
                            </div>
                        </div>

                        <div class="row p-3 mt-4 border border-secondary rounded">
                            <div class="row">
                                <div class="d-flex align-items-center justify-content-between">
                                    <h5>Danh sách sản phẩm</h5>
                                    <button class="btn btn-primary">
                                        <i class="bi bi-plus"></i>
                                        <span>Thêm sản phẩm</span>
                                    </button>
                                </div>
                            </div>



                            <div class="row mt-3">
                                <div class="col-xl-10 d-flex align-items-center justify-content-around">
                                    <div class="">
                                        <label for="supplier" class="form-label">Sản phẩm</label>
                                        <select name="" class="form-select" id="">
                                            <option selected>--Chọn sản phẩm--</option>
                                            <option value="1">TechCore Distribution</option>
                                            <option value="2">CPU VietNam Co.</option>
                                            <option value="3">RAM & Storage Hub</option>
                                        </select>
                                    </div>
                                    <div class="">
                                        <label for="quantity" class="form-label">Số lượng</label>
                                        <input type="text" class="form-control" id="date" name="quantity">
                                    </div>
                                    <div class="">
                                        <label for="price" class="form-label">Giá</label>
                                        <input type="text" class="form-control" name="price" id="price">
                                    </div>
                                </div>

                                <div class="col-xl-2 d-flex justify-content-around align-items-center">
                                    <div class="d-flex flex-column">
                                        <span>Thành tiền</span>
                                        <span>0đ</span>
                                    </div>
                                    <button class="bg-white border-0">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>

                            </div>
                            
                            <div class="row mt-3">
                                <div class="d-flex flex-column align-items-end">
                                    <span>Tổng giá trị đơn hàng</span>
                                    <span>0đ</span>
                                </div>
                            </div>

                            <div class="row mt-3">
                                <div class="d-flex align-items-center justify-content-end">
                                    <button class="rounded me-3">
                                        Lưu nháp
                                    </button>

                                    <button class="btn btn-primary text-white border-0 rounded">
                                        Gửi đơn hàng
                                    </button>
                                </div>

                            </div>
                        </div>
                    </div>
                   
                </form>
            </div>
            <div class="tab-pane container" id="menu4">
                <div class="mt-4">
                    <form action="">
                        <div class="mt-4">
                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#returnRequestModal">
                                <i class="bi bi-plus"></i>
                                <span>Tạo yêu cầu trả hàng</span>
                            </button>
                        </div>
                    </form>
                </div>

                <div class="modal fade" id="returnRequestModal" tabindex="-1" aria-labelledby="returnModalLabel" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content border-0 shadow">
                            
                            <div class="modal-header">
                                <h5 class="modal-title fw-bold" id="returnModalLabel">Tạo yêu cầu trả hàng NCC</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>

                            <div class="modal-body">
                                <form id="returnForm">
                                    <div class="mb-3">
                                        <label for="supplierSelect" class="form-label">Nhà cung cấp</label>
                                        <select class="form-select" id="supplierSelect">
                                            <option selected>TechCore Distribution</option>
                                            <option value="2">GPU Vietnam Co.</option>
                                        </select>
                                    </div>
                                    
                                    <div class="mb-3">
                                        <label for="poSelect" class="form-label">Đơn nhập hàng liên quan</label>
                                        <select class="form-select" id="poSelect">
                                            <option selected>PO-2026-001 - TechCore Distribution</option>
                                        </select>
                                    </div>
                                    
                                    <div class="mb-3">
                                        <label for="reasonText" class="form-label">Lý do trả hàng</label>
                                        <textarea class="form-control" id="reasonText" rows="4" placeholder="Mô tả lý do trả hàng..."></textarea>
                                    </div>
                                </form>
                            </div>

                            <div class="modal-footer border-top-0">
                                <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Hủy</button>
                                <button type="button" class="btn btn-primary px-4">Gửi yêu cầu</button>
                            </div>

                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Mã YÊU CẦU</th>
                                <th>TÊN NHÀ CUNG CẤP</th>
                                <th>SẢN PHẨM</th>
                                <th>LÝ DO</th>
                                <th>SỐ TIỀN</th>
                                <th>TRẠNG THÁI</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr >
                                <td class="border-bottom-0">RTN-002</td>
                                <td class=" border-bottom-0">
                                    GPU Vietnam Co.	
                                </td>
                                <td class=" border-bottom-0">NVIDIA RTX 4090 24GB (x1)</td>
                                <td class=" border-bottom-0">
                                    Card màn hình bị trầy xước	
                                </td>
                                <td class=" border-bottom-0">   
                                    38.000.000 ₫
                                </td>
                                <td class=" border-bottom-0 d-flex items-center justify-content-center"><span class="badge bg-success rounded-pill px-3 py-2">Hoàn thành</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>

@* ========== MODAL THÊM NHÀ CUNG CẤP ========== *@
<div class="modal fade" id="addSupplierModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="AddSupplier" asp-controller="Purchase" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Thêm nhà cung cấp mới</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tên nhà cung cấp <span class="text-danger">*</span></label>
                        <input type="text" name="SupplierName" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Người liên hệ</label>
                        <input type="text" name="ContactPerson" class="form-control">
                    </div>
                    <div class="row">
                        <div class="col mb-3">
                            <label class="form-label fw-semibold">Số điện thoại</label>
                            <input type="text" name="Phone" class="form-control">
                        </div>
                        <div class="col mb-3">
                            <label class="form-label fw-semibold">Email</label>
                            <input type="email" name="Email" class="form-control">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Địa chỉ</label>
                        <input type="text" name="Address" class="form-control">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Thêm</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* ========== MODAL SỬA NHÀ CUNG CẤP ========== *@
<div class="modal fade" id="editSupplierModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="EditSupplier" asp-controller="Purchase" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="SupplierID" id="editSupplierID">
                <div class="modal-header">
                    <h5 class="modal-title">Chỉnh sửa nhà cung cấp</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tên nhà cung cấp <span class="text-danger">*</span></label>
                        <input type="text" name="SupplierName" id="editSupplierName" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Người liên hệ</label>
                        <input type="text" name="ContactPerson" id="editContactPerson" class="form-control">
                    </div>
                    <div class="row">
                        <div class="col mb-3">
                            <label class="form-label fw-semibold">Số điện thoại</label>
                            <input type="text" name="Phone" id="editPhone" class="form-control">
                        </div>
                        <div class="col mb-3">
                            <label class="form-label fw-semibold">Email</label>
                            <input type="email" name="Email" id="editEmail" class="form-control">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Địa chỉ</label>
                        <input type="text" name="Address" id="editAddress" class="form-control">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Điền data vào modal Edit khi bấm nút sửa
        document.getElementById('editSupplierModal').addEventListener('show.bs.modal', function (event) {
            const btn = event.relatedTarget;
            document.getElementById('editSupplierID').value = btn.getAttribute('data-id');
            document.getElementById('editSupplierName').value = btn.getAttribute('data-name');
            document.getElementById('editContactPerson').value = btn.getAttribute('data-contact') || '';
            document.getElementById('editPhone').value = btn.getAttribute('data-phone') || '';
            document.getElementById('editEmail').value = btn.getAttribute('data-email') || '';
            document.getElementById('editAddress').value = btn.getAttribute('data-address') || '';
        });
    </script>
}
