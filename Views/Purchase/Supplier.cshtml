@model SCM_System.Models.ViewModels.SupplierPageViewModel
@{
    ViewData["Title"] = "Mua hàng & NCC";
    bool isVND = Model.CurrencySymbol == "₫";
    string format = isVND ? "N0" : "N2";
}

<div class="container-fluid" style="padding:20px 20px">
    <div class="row">
        <h1 class="fw-bold"><i class="bi bi-truck-flatbed me-2"></i>Mua hàng & Nhà cung cấp</h1>
    </div>

    <div class="row mt-4">
        <ul class="nav nav-tabs" id="purchaseTabs">
            <li class="nav-item">
                <a class="nav-link active" data-bs-toggle="tab" href="#menu1"><i class="bi bi-building me-1"></i>Nhà cung cấp</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#menu2"><i class="bi bi-list-check me-1"></i>Đơn nhập hàng (PO)</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#menu3"><i class="bi bi-cart-plus me-1"></i>Lập đơn nhập mới</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#menu4"><i class="bi bi-arrow-return-left me-1"></i>Trả hàng NCC</a>
            </li>
        </ul>
    </div>

    <div class="row">
        <div class="tab-content border border-top-0 p-4 bg-white shadow-sm rounded-bottom">
            @* TAB 1: NHÀ CUNG CẤP *@
            <div class="tab-pane active" id="menu1">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0">Đối tác cung ứng</h5>
                    <div class="d-flex gap-2">
                        <form asp-action="Supplier" method="get" class="d-flex gap-2">
                            <input type="hidden" name="hash" value="#menu1" />
                            <input type="text" name="searchSupplier" value="@Model.SearchSupplier" class="form-control form-control-sm" placeholder="Tìm nhà cung cấp..." style="width: 250px;">
                            <button type="submit" class="btn btn-sm btn-outline-secondary px-3">Tìm</button>
                        </form>
                        <button class="btn btn-sm btn-primary px-4 shadow-sm fw-bold" data-bs-toggle="modal" data-bs-target="#addSupplierModal">Thêm mới</button>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle border">
                        <thead class="bg-light small">
                            <tr>
                                <th class="ps-3">Mã NCC</th>
                                <th>TÊN NHÀ CUNG CẤP</th>
                                <th>LIÊN HỆ</th>
                                <th class="text-center">SỐ ĐƠN</th>
                                <th class="text-end pe-3">THAO TÁC</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.Suppliers) {
                                <tr>
                                    <td class="ps-3 small text-muted">NCC@(s.SupplierID.ToString("D3"))</td>
                                    <td>
                                        <div class="fw-bold">@s.SupplierName</div>
                                        <small class="text-secondary">@s.Address</small>
                                    </td>
                                    <td>
                                        <div class="small fw-bold">@s.ContactPerson</div>
                                        <div class="small text-muted">@s.Phone</div>
                                    </td>
                                    <td class="text-center"><span class="badge bg-light text-dark border">@s.TotalOrders</span></td>
                                    <td class="text-end pe-3">
                                        <button class="btn btn-sm btn-outline-dark px-3 rounded-pill" data-bs-toggle="modal" data-bs-target="#editSupplierModal" 
                                                data-id="@s.SupplierID" data-name="@s.SupplierName" data-address="@s.Address">Sửa</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @* TAB 2: PO *@
            <div class="tab-pane" id="menu2">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Lịch sử đơn nhập hàng (PO)</h5>
                    <form asp-action="Supplier" method="get" class="d-flex gap-2">
                        <input type="hidden" name="hash" value="#menu2" />
                        <input type="text" name="searchPO" value="@Model.SearchPO" class="form-control form-control-sm" placeholder="Tìm PO hoặc NCC..." style="width: 250px;">
                        <button type="submit" class="btn btn-sm btn-primary px-3">Tìm</button>
                    </form>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover border">
                        <thead class="bg-light small">
                            <tr>
                                <th class="ps-3">MÃ ĐƠN</th>
                                <th>NHÀ CUNG CẤP</th>
                                <th>NGÀY ĐẶT</th>
                                <th class="text-end">GIÁ TRỊ</th>
                                <th>TRẠNG THÁI</th>
                                <th class="text-end pe-3">THAO TÁC</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var po in Model.PurchaseOrders) {
                                <tr>
                                    <td class="ps-3 fw-bold text-primary">PO-@(po.POID.ToString("D5"))</td>
                                    <td class="fw-bold">@po.SupplierName</td>
                                    <td class="small text-muted">@po.OrderDate.ToString("dd/MM/yyyy")</td>
                                    <td class="text-end fw-bold">@po.TotalAmount.ToString(format)</td>
                                    <td>
                                        <span class="badge @(po.Status == "Hoàn thành" ? "bg-success" : "bg-warning") px-3">@po.Status</span>
                                    </td>
                                    <td class="text-end pe-3">
                                        <button class="btn btn-sm btn-outline-primary px-3 rounded-pill" data-id="@po.POID" data-bs-toggle="modal" data-bs-target="#modalPODetail" onclick="viewPODetail(@po.POID)">Chi tiết</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @* TAB 3: TẠO ĐƠN *@
            <div class="tab-pane" id="menu3">
                <div class="bg-light p-4 rounded border">
                    <h5 class="fw-bold mb-4 text-primary">Lập đơn nhập hàng mới</h5>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Nhà cung cấp *</label>
                            <select id="poSupplierID" class="form-select border-primary shadow-sm">
                                <option value="">-- Chọn nhà cung cấp --</option>
                                @foreach (var s in Model.Suppliers) {
                                    <option value="@s.SupplierID">@s.SupplierName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">Ngày giao dự kiến</label>
                            <input type="date" id="poExpectedDate" class="form-control" />
                        </div>
                    </div>
                    <div class="mb-3 d-flex justify-content-between">
                        <h6 class="fw-bold mb-0">Sản phẩm đặt hàng</h6>
                        <button class="btn btn-sm btn-success px-3 shadow-sm" onclick="addPOItemRow()"><i class="bi bi-plus-lg"></i> Thêm dòng</button>
                    </div>
                    <table class="table table-bordered bg-white" id="poItemsTable">
                        <thead class="bg-light small">
                            <tr>
                                <th style="width: 45%">Sản phẩm</th>
                                <th style="width: 15%" class="text-center">Số lượng</th>
                                <th style="width: 20%" class="text-end">Đơn giá (@Model.CurrencySymbol)</th>
                                <th style="width: 20%" class="text-end pe-3">Thành tiền</th>
                                <th style="width: 5%"></th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                    <div class="text-end mt-4">
                        <h4 class="fw-bold text-primary mb-4">Tổng cộng: <span id="poTotalDisplay">@Model.CurrencySymbol 0</span></h4>
                        <button class="btn btn-primary px-5 py-2 fw-bold shadow" onclick="submitPurchaseOrder()">Xác nhận và Gửi đơn</button>
                    </div>
                </div>
            </div>

            @* TAB 4: TRẢ HÀNG *@
            <div class="tab-pane" id="menu4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Quản lý Phiếu trả hàng cho NCC</h5>
                    <form asp-action="Supplier" method="get" class="d-flex gap-2">
                        <input type="hidden" name="hash" value="#menu4" />
                        <input type="text" name="searchReturn" value="@Model.SearchReturn" class="form-control form-control-sm" placeholder="Tìm RTN..." style="width: 200px;">
                        <button type="submit" class="btn btn-danger btn-sm px-3">Tìm</button>
                    </form>
                </div>
                <div class="table-responsive">
                    <table class="table border">
                        <thead class="bg-light small">
                            <tr>
                                <th class="ps-3">MÃ RTN</th>
                                <th>ĐƠN GỐC</th>
                                <th>NHÀ CUNG CẤP</th>
                                <th class="text-end">SỐ TIỀN</th>
                                <th>TRẠNG THÁI</th>
                                <th class="text-end pe-3">THAO TÁC</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.ReturnOrders) {
                                <tr>
                                    <td class="ps-3 fw-bold text-danger">RTN-@(r.ReturnID.ToString("D3"))</td>
                                    <td>PO-@(r.POID.ToString("D5"))</td>
                                    <td>@r.SupplierName</td>
                                    <td class="text-end fw-bold">@r.Amount.ToString(format)</td>
                                    <td><span class="badge @(r.Status == "Hoàn thành" ? "bg-success" : "bg-warning")">@r.Status</span></td>
                                    <td class="text-end pe-3">
                                        <button class="btn btn-sm btn-outline-danger px-3 rounded-pill" onclick="viewReturnDetail(@r.ReturnID)">Chi tiết</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@* MODALS *@
<div class="modal fade" id="modalPODetail" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-primary text-white p-4">
                <h5 class="modal-title fw-bold">Chi tiết đơn nhập PO</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0" id="modalPODetailBody"></div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalReturnDetail" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-danger text-white p-4">
                <h5 class="modal-title fw-bold">Chi tiết phiếu trả hàng RTN</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4" id="modalReturnDetailBody"></div>
        </div>
    </div>
</div>

<div class="modal fade" id="addSupplierModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <form asp-action="AddSupplier" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header bg-primary text-white p-4">
                    <h5 class="modal-title fw-bold">Thêm nhà cung cấp mới</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Tên nhà cung cấp *</label>
                        <input type="text" name="SupplierName" class="form-control" required>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold">Người liên hệ</label>
                            <input type="text" name="ContactPerson" class="form-control">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold">Số điện thoại</label>
                            <input type="text" name="Phone" class="form-control">
                        </div>
                    </div>
                    <div class="mb-0">
                        <label class="form-label small fw-bold">Địa chỉ văn phòng</label>
                        <textarea name="Address" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer p-4 border-0">
                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold shadow">Lưu thông tin</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editSupplierModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <form asp-action="EditSupplier" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="SupplierID" id="editSupplierID" />
                <div class="modal-header bg-dark text-white p-4">
                    <h5 class="modal-title fw-bold">Sửa nhà cung cấp</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Tên nhà cung cấp *</label>
                        <input type="text" name="SupplierName" id="editSupplierName" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Địa chỉ</label>
                        <textarea name="Address" id="editAddress" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer p-4 border-0">
                    <button type="submit" class="btn btn-dark w-100 rounded-pill py-2 fw-bold shadow">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            let hash = window.location.hash || "#menu1";
            let triggerEl = document.querySelector('.nav-link[href="' + hash + '"]');
            if (triggerEl) bootstrap.Tab.getOrCreateInstance(triggerEl).show();

            document.querySelectorAll('.nav-link[data-bs-toggle="tab"]').forEach(tab => {
                tab.addEventListener('shown.bs.tab', e => {
                    location.hash = tab.getAttribute('href');
                });
            });

            addPOItemRow();
        });

        function viewPODetail(id) {
            $('#modalPODetailBody').html('<div class="text-center py-5"><div class="spinner-border text-primary"></div></div>');
            $.get('/Purchase/PODetails/' + id, d => $('#modalPODetailBody').html(d));
            new bootstrap.Modal(document.getElementById('modalPODetail')).show();
        }

        function viewReturnDetail(id) {
            $('#modalReturnDetailBody').html('<div class="text-center py-5"><div class="spinner-border text-danger"></div></div>');
            $.get('/Purchase/ReturnDetails/' + id, d => $('#modalReturnDetailBody').html(d));
            new bootstrap.Modal(document.getElementById('modalReturnDetail')).show();
        }

        const symbol = '@Model.CurrencySymbol';
        const rate = symbol === '₫' ? 1 : (symbol === '$' ? 25000 : 27000);
        const products = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AvailableProducts.Select(p => new { p.ProductID, p.ProductName, p.BasePrice })));

        window.addPOItemRow = function() {
            const id = Date.now();
            const tr = document.createElement('tr');
            tr.id = `row-${id}`;
            tr.innerHTML = `
                <td><select class="form-select item-p" onchange="updR(${id})"><option value="">-- Chọn SP --</option>${products.map(p=>`<option value="${p.ProductID}">${p.ProductName}</option>`).join('')}</select></td>
                <td><input type="number" class="form-control text-center item-q" value="1" min="1" onchange="updR(${id})"></td>
                <td><input type="number" class="form-control text-end item-pr" value="0" readonly></td>
                <td class="text-end fw-bold pe-3 item-t">${symbol} 0</td>
                <td class="text-center"><button type="button" class="btn btn-link text-danger p-0" onclick="remR(${id})"><i class="bi bi-x-circle fs-5"></i></button></td>
            `;
            document.querySelector('#poItemsTable tbody').appendChild(tr);
        };

        window.updR = i => {
            const r = document.getElementById(`row-${i}`);
            const pId = parseInt(r.querySelector('.item-p').value);
            const p = products.find(x => x.ProductID === pId);
            if(p) r.querySelector('.item-pr').value = (p.BasePrice/rate).toFixed(symbol==='₫'?0:2);
            const q = r.querySelector('.item-q').value || 0;
            const pr = r.querySelector('.item-pr').value || 0;
            r.querySelector('.item-t').innerText = symbol + ' ' + (q*pr).toLocaleString();
            calcT();
        };

        window.remR = i => { document.getElementById(`row-${i}`).remove(); calcT(); };

        function calcT() {
            let t = 0;
            document.querySelectorAll('#poItemsTable tbody tr').forEach(r => t += (r.querySelector('.item-q').value * r.querySelector('.item-pr').value));
            document.getElementById('poTotalDisplay').innerText = symbol + ' ' + t.toLocaleString();
        }

        window.submitPurchaseOrder = async function() {
            const sId = document.getElementById('poSupplierID').value;
            if(!sId) return alert('Chọn NCC');
            const items = [];
            document.querySelectorAll('#poItemsTable tbody tr').forEach(r => {
                const pId = r.querySelector('.item-p').value;
                if(pId) items.push({ ProductID: parseInt(pId), Quantity: parseInt(r.querySelector('.item-q').value), Price: parseFloat(r.querySelector('.item-pr').value) * rate });
            });
            if(!items.length) return alert('Chọn SP');
            const res = await fetch('/Purchase/CreatePurchaseOrder', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                body: JSON.stringify({ SupplierID: parseInt(sId), Items: items })
            });
            if(res.ok) location.reload();
        };

        $('#editSupplierModal').on('show.bs.modal', function(e) {
            const b = e.relatedTarget;
            $('#editSupplierID').val(b.dataset.id);
            $('#editSupplierName').val(b.dataset.name);
            $('#editAddress').val(b.dataset.address);
        });
    </script>
}
