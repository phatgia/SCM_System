<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SCM System</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="container-fluid vh-100 bg-light">
    <div class="row h-100">
        <div class="col-12 col-md-6 h-100 text-white d-flex flex-column justify-content-center p-5" style="background: linear-gradient(to right, blue, rgb(55, 142, 255));">
            <i class="bi bi-box-seam text-primary text-white" style="font-size: 5rem;"></i>
            <h3 class="mt-2 fw-bold">SCM System</h3>
            <P>Tối ưu hóa quy trình mua hàng, quản lý kho, vận chuyển</br> và bán hàng cho doanh nghiệp linh kiện máy tính.</P>
        </div>

        <div class="col-12 col-md-6 h-100 bg-white d-flex flex-column justify-content-center p-5">
            @RenderBody()
        </div>
        
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>