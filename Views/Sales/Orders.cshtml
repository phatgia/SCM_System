@model SCM_System.Models.ViewModels.SalesOrdersViewModel
@{
    ViewData["Title"] = "Bán hàng & Xuất kho - Đơn hàng";
    bool isVND = Model.CurrencySymbol == "₫";
    string format = isVND ? "N0" : "N2";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-1">Bán hàng & Xuất kho</h4>
        <p class="text-muted small mb-0">Tạo đơn, tra cứu tồn kho và xử lý đổi trả</p>
    </div>
</div>

<ul class="nav nav-tabs mb-4">
    <li class="nav-item"><a class="nav-link" asp-action="Create"><i class="bi bi-receipt me-1"></i>Tạo đơn bán</a></li>
    <li class="nav-item"><a class="nav-link active" asp-action="Orders"><i class="bi bi-cart-plus me-1"></i>Đơn bán hàng</a></li>
    <li class="nav-item"><a class="nav-link" asp-action="Stock"><i class="bi bi-boxes me-1"></i>Tra cứu tồn kho</a></li>
    <li class="nav-item"><a class="nav-link" asp-action="Returns"><i class="bi bi-arrow-left-right me-1"></i>Đổi trả hàng</a></li>
</ul>

<div class="tab-content">
    <div class="tab-pane active">
        <!-- FILTER -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body p-3">
                <form asp-action="Orders" method="get">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold">Tìm kiếm</label>
                            <div class="input-group input-group-sm">
                                <input type="text" name="search" value="@ViewBag.SearchTerm" class="form-control" placeholder="Mã đơn hoặc tên khách...">
                                <button type="submit" class="btn btn-primary px-3 shadow-sm"><i class="bi bi-search me-1"></i>Tìm</button>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <a asp-action="Orders" class="btn btn-sm btn-outline-secondary">Xóa lọc</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- TABLE -->
        <div class="card border-0 shadow-sm overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="bg-light">
                        <tr class="text-muted small">
                            <th class="ps-4 py-3 border-0">MÃ ĐƠN</th>
                            <th class="py-3 border-0">KHÁCH HÀNG</th>
                            <th class="py-3 border-0">SẢN PHẨM</th>
                            <th class="py-3 border-0">TỔNG TIỀN</th>
                            <th class="py-3 border-0">NGÀY TẠO</th>
                            <th class="py-3 border-0">TRẠNG THÁI</th>
                            <th class="py-3 border-0 text-center">CHI TIẾT</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Orders.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted small">Chưa có đơn hàng nào.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var order in Model.Orders)
                            {
                                <tr>
                                    <td class="ps-4 py-2 fw-bold small text-primary">@order.OrderCode</td>
                                    <td class="py-2">
                                        <div class="small fw-bold text-dark">@order.CustomerName</div>
                                        <div class="small text-muted">@order.CustomerPhone</div>
                                    </td>
                                    <td class="py-2 small text-muted">@order.ProductSummary</td>
                                    <td class="py-2 small fw-bold text-dark">@Model.CurrencySymbol@order.TotalAmount.ToString(format)</td>
                                    <td class="py-2 small text-muted">@order.OrderDate.ToString("dd/MM/yyyy")</td>
                                    <td class="py-2">
                                        @{
                                            var badgeClass = order.Status switch
                                            {
                                                "Hoàn thành" => "bg-success",
                                                "Đang xử lý" => "bg-info",
                                                "Đã soạn xong" => "bg-warning",
                                                "Đang giao hàng" => "bg-primary",
                                                "Đã hủy" => "bg-danger",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @badgeClass bg-opacity-10 text-@badgeClass.Replace("bg-", "") fw-semibold px-2">@order.Status</span>
                                    </td>
                                    <td class="py-2 text-center">
                                        <button class="btn btn-sm btn-light border btn-view-details" 
                                                data-id="@order.SOID" data-code="@order.OrderCode"
                                                data-bs-toggle="modal" data-bs-target="#modalChiTiet">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Chi tiết đơn -->
<div class="modal fade" id="modalChiTiet" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 bg-light p-4">
                <h5 class="modal-title fw-bold" id="modalTitle">Chi tiết đơn hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4" id="modalBody">
                <!-- Data loaded via AJAX -->
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2 text-muted small">Đang tải dữ liệu...</p>
                </div>
            </div>
            <div class="modal-footer border-0 p-4">
                <button class="btn btn-light border px-4" data-bs-dismiss="modal">Đóng</button>
                <button class="btn btn-primary px-4 shadow-sm" onclick="window.print()"><i class="bi bi-printer me-1"></i>In phiếu</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.btn-view-details').on('click', function () {
                const orderId = $(this).data('id');
                const orderCode = $(this).data('code');
                
                $('#modalTitle').text('Chi tiết đơn hàng — ' + orderCode);
                $('#modalBody').html('<div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div><p class="mt-2 text-muted small">Đang lấy dữ liệu chi tiết...</p></div>');

                $.get('/Sales/OrderDetails/' + orderId, function (data) {
                    $('#modalBody').html(data);
                }).fail(function () {
                    $('#modalBody').html('<div class="alert alert-danger">Không thể tải thông tin đơn hàng này.</div>');
                });
            });
        });
    </script>
}
