@model SCM_System.Models.ViewModels.SalesStockViewModel
@{
    ViewData["Title"] = "Bán hàng & Xuất kho - Tồn kho";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-1">Bán hàng & Xuất kho</h4>
        <p class="text-muted small mb-0">Tạo đơn, tra cứu tồn kho và xử lý đổi trả</p>
    </div>
</div>

<ul class="nav nav-tabs mb-4">
    <li class="nav-item"><a class="nav-link" asp-action="Create"><i class="bi bi-receipt me-1"></i>Tạo đơn bán</a></li>
    <li class="nav-item"><a class="nav-link" asp-action="Orders"><i class="bi bi-cart-plus me-1"></i>Đơn bán hàng</a></li>
    <li class="nav-item"><a class="nav-link active" asp-action="Stock"><i class="bi bi-boxes me-1"></i>Tra cứu tồn kho</a></li>
    <li class="nav-item"><a class="nav-link" asp-action="Returns"><i class="bi bi-arrow-left-right me-1"></i>Đổi trả hàng</a></li>
</ul>

<div class="tab-content">
    <div class="tab-pane active">
        <!-- FILTER -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body p-3">
                <form asp-action="Stock" method="get">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Tên / Mã linh kiện</label>
                            <div class="input-group input-group-sm">
                                <input type="text" name="search" value="@ViewBag.SearchTerm" class="form-control" placeholder="Tìm theo tên linh kiện...">
                                <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> Tìm kiếm</button>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-semibold">Danh mục</label>
                            <select name="categoryId" class="form-select form-select-sm" onchange="this.form.submit()">
                                <option value="">Tất cả danh mục</option>
                                @foreach (var cat in Model.Categories)
                                {
                                    <option value="@cat.CategoryID" selected="@(ViewBag.CategoryId == cat.CategoryID)">@cat.CategoryName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <a asp-action="Stock" class="btn btn-sm btn-outline-secondary">Xóa lọc</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- STOCK TABLE -->
        <div class="card border-0 shadow-sm overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="bg-light">
                        <tr class="text-muted small">
                            <th class="ps-4 py-3 border-0">SẢN PHẨM</th>
                            <th class="py-3 border-0">DANH MỤC</th>
                            <th class="py-3 border-0 text-center">TỒN THỰC TẾ</th>
                            <th class="py-3 border-0 text-center">ĐANG GIỮ CHỖ</th>
                            <th class="py-3 border-0 text-center">KHẢ DỤNG</th>
                            <th class="py-3 border-0">VỊ TRÍ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Stocks.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted small">Không tìm thấy sản phẩm nào trong kho.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model.Stocks)
                            {
                                <tr>
                                    <td class="ps-4 py-2">
                                        <div class="small fw-bold text-dark">@item.ProductName</div>
                                        <div class="small text-muted">@item.SKU</div>
                                    </td>
                                    <td class="py-2 small text-muted">@item.CategoryName</td>
                                    <td class="py-2 text-center fw-bold small">@item.PhysicalStock</td>
                                    <td class="py-2 text-center text-warning small">@item.ReservedStock</td>
                                    <td class="py-2 text-center">
                                        @{
                                            var badgeClass = item.AvailableStock <= 5 ? "bg-danger" : (item.AvailableStock <= 15 ? "bg-warning" : "bg-success");
                                        }
                                        <span class="badge @badgeClass px-2 fw-semibold">@item.AvailableStock</span>
                                    </td>
                                    <td class="py-2 small text-muted"><i class="bi bi-geo-alt me-1"></i>@item.LocationName</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>