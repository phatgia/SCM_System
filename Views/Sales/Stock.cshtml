                    <tr><td class="ps-4 py-2"><div class="small fw-semibold">NVIDIA RTX 4090 24GB</div><div class="small text-muted">SKU: GPU-4090-24G</div></td><td class="py-2 small">GPU</td><td class="py-2 small fw-semibold">8</td><td class="py-2 small text-warning">2</td><td class="py-2"><span class="badge bg-warning px-2 fw-semibold">6</span></td><td class="py-2 small text-muted">B-02</td></tr>
                    <tr><td class="ps-4 py-2"><div class="small fw-semibold">Corsair Vengeance DDR5 32GB</div><div class="small text-muted">SKU: RAM-DDR5-32G</div></td><td class="py-2 small">RAM</td><td class="py-2 small fw-semibold">45</td><td class="py-2 small text-warning">5</td><td class="py-2"><span class="badge bg-success px-2 fw-semibold">40</span></td><td class="py-2 small text-muted">C-01</td></tr>
                    <tr><td class="ps-4 py-2"><div class="small fw-semibold">Samsung 990 Pro 2TB</div><div class="small text-muted">SKU: SSD-990P-2T</div></td><td class="py-2 small">SSD</td><td class="py-2 small fw-semibold">20</td><td class="py-2 small text-warning">4</td><td class="py-2"><span class="badge bg-success px-2 fw-semibold">16</span></td><td class="py-2 small text-muted">A-02</td></tr>
