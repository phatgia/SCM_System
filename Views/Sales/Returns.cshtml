@model SCM_System.Models.ViewModels.SalesReturnViewModel
@{
    ViewData["Title"] = "Bán hàng & Xuất kho";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-1">Bán hàng & Xuất kho</h4>
        <p class="text-muted small mb-0">Tạo đơn, tra cứu tồn kho và xử lý đổi trả</p>
    </div>
</div>

<ul class="nav nav-tabs mb-4">
    <li class="nav-item"><a class="nav-link" href="/Sales/Create"><i class="bi bi-receipt me-1"></i>Tạo đơn bán</a></li>
    <li class="nav-item"><a class="nav-link" href="/Sales/Orders"><i class="bi bi-cart-plus me-1"></i>Đơn bán hàng</a></li>
    <li class="nav-item"><a class="nav-link" href="/Sales/Stock"><i class="bi bi-boxes me-1"></i>Tra cứu tồn kho</a></li>
    <li class="nav-item"><a class="nav-link active" href="/Sales/Returns"><i class="bi bi-arrow-left-right me-1"></i>Đổi trả hàng</a></li>
</ul>

<div class="tab-content">
    <!-- ĐỔI TRẢ HÀNG -->
    <div class="tab-pane active" id="tab-doitra">
        <div class="d-flex justify-content-between align-items-center mb-4 px-3 py-2 bg-white rounded-3 shadow-sm border">
            <div>
                <h6 class="fw-bold mb-0 text-primary">Yêu cầu đổi trả & Hoàn hàng</h6>
                <p class="text-muted small mb-0">Tra cứu và xử lý các yêu cầu từ khách hàng</p>
            </div>
            <div class="d-flex gap-3">
                <form asp-action="Returns" method="get" class="d-flex gap-2">
                    <input type="text" name="search" value="@ViewContext.HttpContext.Request.Query["search"]" class="form-control form-control-sm border-0 bg-light rounded-pill px-4" placeholder="Tìm Mã SO hoặc Khách..." style="min-width: 280px;">
                    <button type="submit" class="btn btn-sm btn-primary rounded-pill px-4 shadow-sm fw-bold">Tìm</button>
                    @if (!string.IsNullOrEmpty(ViewContext.HttpContext.Request.Query["search"]))
                    {
                        <a href="/Sales/Returns" class="btn btn-link btn-sm text-decoration-none text-secondary">Xóa</a>
                    }
                </form>
                <button class="btn btn-sm btn-dark rounded-pill px-4 fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#modalDoiTra">
                    <i class="bi bi-plus-lg me-1"></i> Tạo mới
                </button>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card border-0 shadow-sm overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr class="text-muted small">
                            <th class="ps-4 py-2 border-0">MÃ YÊU CẦU</th>
                            <th class="py-2 border-0">ĐƠN GỐC</th>
                            <th class="py-2 border-0">KHÁCH HÀNG</th>
                            <th class="py-2 border-0">SẢN PHẨM</th>
                            <th class="py-2 border-0">XỬ LÝ (Settlement)</th>
                            <th class="py-2 border-0">TRẠNG THÁI</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Returns.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted small">Chưa có yêu cầu đổi trả nào.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var r in Model.Returns)
                            {
                                <tr>
                                    <td class="ps-4 py-2 fw-semibold small text-primary">@r.RequestCode</td>
                                    <td class="py-2 small fw-bold">@r.SaleOrderCode</td>
                                    <td class="py-2 small">@r.CustomerName</td>
                                    <td class="py-2 small text-muted">@r.ProductSummary</td>
                                    <td class="py-2 small">
                                        <span class="badge rounded-pill bg-secondary bg-opacity-10 text-secondary">@r.Settlement</span>
                                    </td>
                                    <td class="py-2">
                                        @{
                                            var badgeClass = r.Status == "Đang xử lý" ? "bg-warning" : "bg-success";
                                        }
                                        <span class="badge @badgeClass bg-opacity-10 text-@badgeClass.Replace("bg-", "") px-2">@r.Status</span>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Đổi trả -->
<div class="modal fade" id="modalDoiTra" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form asp-action="CreateReturn" method="post">
                <div class="modal-header border-0">
                    <h5 class="modal-title fw-bold">Tạo yêu cầu đổi trả</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Đơn hàng gốc *</label>
                        <select name="SOID" class="form-select shadow-sm" required>
                            <option value="">-- Chọn đơn hàng --</option>
                            @foreach (var so in Model.SaleOrders)
                            {
                                <option value="@so.SOID">SO-@so.SOID.ToString("D4") - @so.Customer.Name (@so.TotalAmount.ToString("N0") ₫)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Hình thức xử lý (Settlement) *</label>
                        <select name="Settlement" class="form-select shadow-sm" required>
                            <option value="Đổi mới">Đổi mới</option>
                            <option value="Hoàn tiền">Hoàn tiền</option>
                            <option value="Bảo hành">Sửa chữa / Bảo hành</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Lý do đổi trả *</label>
                        <textarea name="Reason" class="form-control shadow-sm" rows="3" placeholder="Mô tả chi tiết lý do..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary px-4 shadow">Xác nhận tạo yêu cầu</button>
                </div>
            </form>
        </div>
    </div>
</div>
