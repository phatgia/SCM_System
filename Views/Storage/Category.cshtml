@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            
            // 1. Hàm đồng bộ Tab và Sidebar
            function syncPurchaseUI() {
                let hash = window.location.hash || "#menu1"; 
                
                // Mở Tab tương ứng
                let targetTab = document.querySelector('.nav-tabs a[href="' + hash + '"]');
                if (targetTab) {
                    new bootstrap.Tab(targetTab).show();
                }

                // Reset toàn bộ màu của menu Mua Hàng về màu xám
                document.querySelectorAll('#quanLyKhoMenu .sidebar-link').forEach(link => {
                    link.classList.remove('bg-success', 'text-white');
                    link.classList.add('text-secondary');
                });

                // Tìm và tô màu xanh cho thẻ a khớp với hash hiện tại
                let activeSidebarLink = document.querySelector('#quanLyKhoMenu a[href$="' + hash + '"]');
                if (activeSidebarLink) {
                    activeSidebarLink.classList.remove('text-secondary');
                    activeSidebarLink.classList.add('bg-success', 'text-white', 'rounded');
                }
            }

            // 2. Chạy lần đầu khi load trang
            syncPurchaseUI();

            // 3. Khi bấm Tab trên màn hình -> Cập nhật URL và Sidebar
            document.querySelectorAll('.nav-tabs a[data-bs-toggle="tab"]').forEach(function (tab) {
                tab.addEventListener('shown.bs.tab', function (event) {
                    let currentHash = event.target.getAttribute('href');
                    history.replaceState(null, null, currentHash);
                    syncPurchaseUI(); 
                });
            });

            // 4. Khi bấm link trên Sidebar -> Đồng bộ lại Tab
            window.addEventListener('hashchange', function() {
                syncPurchaseUI();
            });

            
            let checkboxes = document.querySelectorAll('.pick-checkbox');
            
            checkboxes.forEach(function(checkbox) {
                // Lắng nghe sự kiện khi người dùng click vào checkbox
                checkbox.addEventListener('change', function() {
                    // Tìm ngược lên thẻ div bọc ngoài cùng của sản phẩm đó (class pick-row)
                    let row = this.closest('.pick-row');
                    
                    // Nếu được tick -> thêm class làm mờ chữ, Nếu bỏ tick -> xóa class
                    if(this.checked) {
                        row.classList.add('item-completed');
                    } else {
                        row.classList.remove('item-completed');
                    }
                });
            });
        });

        
        document.querySelectorAll('.btn-edit').forEach(btn => {
            btn.addEventListener('click', function() {
                let tr = this.closest('tr'); // Tìm dòng <tr> chứa nút này
                
                // Ẩn chữ tĩnh, hiện ô input
                tr.querySelector('.stock-text').classList.add('d-none');
                tr.querySelector('.stock-input').classList.remove('d-none');
                
                // Ẩn nút "Điều chỉnh", hiện cụm "Lưu/Hủy"
                tr.querySelector('.btn-edit').classList.add('d-none');
                tr.querySelector('.edit-actions').classList.remove('d-none');
                
                // Tự động focus (nháy con trỏ chuột) vào ô input cho tiện gõ
                tr.querySelector('.stock-input').focus();
            });
        });

        document.querySelectorAll('.btn-cancel').forEach(btn => {
            btn.addEventListener('click', function() {
                let tr = this.closest('tr');
                
                // Khôi phục lại giá trị của input bằng với con số cũ (đề phòng user đã gõ bậy)
                let originalValue = tr.querySelector('.stock-text').innerText;
                tr.querySelector('.stock-input').value = originalValue;

                // Ẩn input, hiện lại chữ tĩnh
                tr.querySelector('.stock-text').classList.remove('d-none');
                tr.querySelector('.stock-input').classList.add('d-none');
                
                // Ẩn cụm "Lưu/Hủy", hiện lại "Điều chỉnh"
                tr.querySelector('.btn-edit').classList.remove('d-none');
                tr.querySelector('.edit-actions').classList.add('d-none');
            });
        });


        document.querySelectorAll('.btn-save').forEach(btn => {
            btn.addEventListener('click', function() {
                let tr = this.closest('tr');
                
                // Lấy con số mới mà user vừa gõ vào
                let newValue = tr.querySelector('.stock-input').value;
                
                // Cập nhật con số đó lên giao diện chữ tĩnh
                tr.querySelector('.stock-text').innerText = newValue;

                // Trả giao diện về trạng thái ban đầu
                tr.querySelector('.stock-text').classList.remove('d-none');
                tr.querySelector('.stock-input').classList.add('d-none');
                
                tr.querySelector('.btn-edit').classList.remove('d-none');
                tr.querySelector('.edit-actions').classList.add('d-none');
                
                // (Tương lai khi nối Backend: Chỗ này em sẽ dùng fetch/ajax để gửi newValue xuống C# lưu vào Database)
            });
        });

    </script>
}