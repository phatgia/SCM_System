@model SCM_System.Models.ViewModels.StoragePageViewModel
@{
    ViewData["Title"] = "Quản lý Kho vận";
}

<div class="container-fluid" style="padding:20px 20px">
    <div class="row">
        <h1 class="fw-bold"><i class="bi bi-box-seam me-2"></i>Quản lý Kho vận</h1>
    </div>

    <div class="row mt-4">
        <ul class="nav nav-tabs" id="storageTabs">
            <li class="nav-item">
                <a class="nav-link active" data-bs-toggle="tab" href="#menu1"><i class="bi bi-download me-1"></i>Nhập kho (PO)</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#menu2"><i class="bi bi-grid-3x3-gap me-1"></i>Vị trí/Zone</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#menu3"><i class="bi bi-cart-check me-1"></i>Soạn & Đóng gói</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#menu4"><i class="bi bi-search me-1"></i>Kiểm kê chi tiết</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#menu5"><i class="bi bi-send-check me-1"></i>Bàn giao</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#menu6"><i class="bi bi-arrow-return-left me-1"></i>Hàng hoàn</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#menu7"><i class="bi bi-shield-check me-1"></i>Kiểm soát QC</a>
            </li>
        </ul>
    </div>

    <div class="row">
        <div class="tab-content border border-top-0 p-4 bg-white shadow-sm rounded-bottom">
            @* TAB 1: NHẬP HÀNG *@
            <div class="tab-pane active" id="menu1">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Đơn PO chờ nhập kho</h5>
                    <form asp-action="Category" method="get" class="d-flex gap-2">
                        <input type="hidden" name="hash" value="#menu1" />
                        <input type="text" name="searchReceipt" value="@ViewBag.SearchReceipt" class="form-control form-control-sm" placeholder="Tìm PO hoặc NCC..." style="width: 250px;">
                        <button type="submit" class="btn btn-primary btn-sm px-3">Tìm</button>
                    </form>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="bg-light text-muted small">
                            <tr>
                                <th>MÃ ĐƠN</th>
                                <th>NHÀ CUNG CẤP</th>
                                <th>NGÀY ĐẶT</th>
                                <th>TRẠNG THÁI</th>
                                <th class="text-end">THAO TÁC</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var po in Model.InboundOrders) {
                                <tr>
                                    <td class="fw-bold text-primary">#PO-@po.POID.ToString("D5")</td>
                                    <td>@po.SupplierName</td>
                                    <td class="text-muted small">@po.OrderDate.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <span class="badge @(po.Status == "Đang xử lý" ? "bg-warning" : "bg-primary") bg-opacity-10 text-@(po.Status == "Đang xử lý" ? "warning" : "primary") px-3">@po.Status</span>
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-primary rounded-pill px-4 shadow-sm" onclick="showInboundConfirm(@po.POID)">Xử lý nhập</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @* TAB 2: VÀNG *@
            <div class="tab-pane" id="menu2">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0">Sơ đồ và Sức chứa Zone</h5>
                    <button class="btn btn-sm btn-success rounded-pill px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#addLocationModal">
                        <i class="bi bi-plus-lg me-1"></i> Thêm vị trí mới
                    </button>
                </div>
                <div class="row g-4">
                    @foreach (var zone in Model.Zones) {
                        <div class="col-md-4">
                            <div class="card border rounded-3 p-3">
                                <div class="d-flex justify-content-between mb-2">
                                    <h6 class="fw-bold mb-0">@zone.ZoneName</h6>
                                    <span class="small fw-bold @(zone.OccupancyRate > 80 ? "text-danger" : "text-success")">@zone.OccupancyRate.ToString("0")%</span>
                                </div>
                                <div class="progress mb-2" style="height: 10px;">
                                    <div class="progress-bar @(zone.OccupancyRate > 80 ? "bg-danger" : "bg-primary")" style="width: @zone.OccupancyRate%"></div>
                                </div>
                                <div class="d-flex justify-content-between small text-muted">
                                    <span>Sức chứa: @zone.TotalCapacity</span>
                                    <span>Đã dùng: @zone.TotalUsed</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            @* TAB 3: SOẠN HÀNG *@
            <div class="tab-pane" id="menu3">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Danh sách soạn hàng (Picking List)</h5>
                    <form asp-action="Category" method="get" class="d-flex gap-2">
                        <input type="hidden" name="hash" value="#menu3" />
                        <input type="text" name="searchPick" value="@ViewBag.SearchPick" class="form-control form-control-sm" placeholder="Mã SO hoặc khách hàng..." style="width: 250px;">
                        <button type="submit" class="btn btn-primary btn-sm px-3">Tìm</button>
                    </form>
                </div>
                <div class="accordion" id="pickAcc">
                    @foreach (var so in Model.PickingOrders) {
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed py-3" type="button" data-bs-toggle="collapse" data-bs-target="#so-@so.SOID">
                                    <strong class="text-dark me-3">#SO-@so.SOID.ToString("D5")</strong> - @so.CustomerName
                                </button>
                            </h2>
                            <div id="so-@so.SOID" class="accordion-collapse collapse" data-bs-parent="#pickAcc">
                                <div class="accordion-body bg-light">
                                    <table class="table table-sm bg-white border">
                                        <thead class="bg-light small">
                                            <tr>
                                                <th class="ps-3">Sản phẩm</th>
                                                <th>SL</th>
                                                <th>Vị trí gợi ý</th>
                                                <th>Tồn kho tại chỗ</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in so.Items) {
                                                <tr>
                                                    <td class="ps-3 py-2">@item.ProductName</td>
                                                    <td class="fw-bold">@item.Quantity</td>
                                                    <td><span class="badge bg-dark">@item.SuggestedLocationCode</span></td>
                                                    <td>@item.StockAtLocation</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                    <div class="text-end mt-3">
                                        <button class="btn btn-primary btn-sm px-4 shadow" onclick="showPickingConfirm(@so.SOID)">Hoàn tất soạn hàng</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            @* TAB 4: KIỂM KÊ *@
            <div class="tab-pane" id="menu4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Kiểm kê tồn kho chi tiết</h5>
                    <form asp-action="Category" method="get" class="d-flex gap-2">
                        <input type="hidden" name="hash" value="#menu4" />
                        <input type="text" name="searchInv" value="@ViewBag.SearchInv" class="form-control form-control-sm" placeholder="Sản phẩm hoặc mã vị trí..." style="width: 250px;">
                        <button type="submit" class="btn btn-dark btn-sm px-3">Lọc</button>
                    </form>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm align-middle border">
                        <thead class="bg-light text-muted small">
                            <tr>
                                <th class="ps-3 py-2">SẢN PHẨM</th>
                                <th>VỊ TRÍ</th>
                                <th>TỒN KHO THỰC TẾ</th>
                                <th>TRẠNG THÁI</th>
                                <th class="text-end pe-3">THAO TÁC</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var inv in Model.InventoryItems) {
                                <tr>
                                    <td class="ps-3 py-2 fw-bold">@inv.ProductName</td>
                                    <td><span class="badge bg-light text-dark border">@inv.LocationCode</span></td>
                                    <td class="fw-bold text-primary">@inv.QuantityAvailable</td>
                                    <td>
                                        <span class="badge @(inv.Status == "Sắp hết" ? "bg-danger" : "bg-success") px-3">@inv.Status</span>
                                    </td>
                                    <td class="text-end pe-3">
                                        <button class="btn btn-sm btn-outline-dark px-3 rounded-pill" onclick="showEditInventory(@inv.ProductID, @inv.LocationID, '@inv.ProductName', @inv.QuantityAvailable)">Sửa</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @* TAB 5: BÀN GIAO *@
            <div class="tab-pane" id="menu5">
                <div class="row">
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-white border-0 pt-3 pb-0 px-4">
                                <h6 class="fw-bold mb-0"><i class="bi bi-qr-code me-1 text-primary"></i>Bàn giao xuất kho (Handshake 1)</h6>
                            </div>
                            <div class="card-body">
                                <p class="small text-muted mb-3">Thủ kho tạo mã QR để Shipper quét xác nhận nhận hàng từ kho.</p>
                                <div class="mb-3">
                                    <label class="form-label small fw-semibold">Chọn đơn hàng</label>
                                    <select class="form-select" id="pickupSelect">
                                        <option value="">-- Chọn đơn hàng --</option>
                                        @foreach(var item in Model.PendingExports){
                                            <option value="@item.DeliveryID">@item.OrderCode - @item.CustomerName</option>
                                        }
                                    </select>
                                </div>
                                <button class="btn btn-primary w-100 " onclick="GenQRCode()"><i class="bi bi-qr-code me-1"></i>Tạo mã QR Handshake</button>
                                <div class="mt-3 text-center d-none" id="qrDisplay">
                                    <div class="border rounded p-3 d-inline-block bg-white">
                                        <div id="qrcodeCanvas" class="d-flex align-items-center justify-content-center"></div>
                                    </div>
                                    <p class="small text-muted mt-2">Mã hết hạn sau <strong>5 phút</strong></p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* TAB 6: HÀNG HOÀN *@
            <div class="tab-pane" id="menu6">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Yêu cầu trả hàng/Hoàn hàng</h5>
                    <form asp-action="Category" method="get" class="d-flex gap-2">
                        <input type="hidden" name="hash" value="#menu6" />
                        <input type="text" name="searchReturn" value="@ViewBag.SearchReturn" class="form-control form-control-sm" placeholder="Tìm RTN..." style="width: 200px;">
                        <button type="submit" class="btn btn-primary btn-sm px-3">Tìm</button>
                    </form>
                </div>
                <div class="table-responsive">
                    <table class="table border">
                        <thead class="bg-light small">
                            <tr>
                                <th class="ps-3">MÃ RTN</th>
                                <th>LIÊN QUAN</th>
                                <th>LÝ DO</th>
                                <th>TRẠNG THÁI</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.Returns) {
                                <tr>
                                    <td class="ps-3 fw-bold">RTN-@r.ReturnID.ToString("D3")</td>
                                    <td class="small">SO-@r.SOID (@r.CustomerName)</td>
                                    <td class="small text-muted">@r.Reason</td>
                                    <td><span class="badge @(r.Status == "Hoàn thành" ? "bg-success" : "bg-warning")">@r.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>


            @* TAB 7: QC *@
            <div class="tab-pane" id="menu7">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Kiểm soát chất lượng (QC)</h5>
                    <div class="d-flex gap-2">
                        <form asp-action="Category" method="get" class="d-flex gap-2">
                            <input type="hidden" name="hash" value="#menu7" />
                            <input type="text" name="searchQC" value="@ViewBag.SearchQC" class="form-control form-control-sm" placeholder="Tham chiếu...">
                            <button type="submit" class="btn btn-primary btn-sm px-3">Tìm</button>
                        </form>
                        <button class="btn btn-sm btn-info text-white px-4 fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#createQCModal">Tạo phiếu QC</button>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover border">
                        <thead class="bg-light small fw-bold">
                            <tr>
                                <th>THAM CHIẾU</th>
                                <th>SẢN PHẨM</th>
                                <th class="text-center">KẾT QUẢ</th>
                                <th>NGÀY KIỂM</th>
                                <th>CÁN BỘ KIỂM</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var qc in Model.QCRecords) {
                                <tr>
                                    <td class="fw-bold">@qc.ReferenceID</td>
                                    <td class="text-info fw-bold">@qc.ProductName</td>
                                    <td class="text-center"><span class="badge @(qc.Result == "Đạt" ? "bg-success" : "bg-danger") px-3">@qc.Result</span></td>
                                    <td class="small">@qc.CheckDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="small text-muted">@qc.InspectorName</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>

@* MODALS *@
<div class="modal fade" id="confirmActionModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-primary text-white border-0 py-3">
                <h5 class="modal-title fw-bold" id="confirmActionTitle">Xác nhận thao tác</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <p class="fs-5 mb-0" id="confirmActionBody">...</p>
            </div>
            <div class="modal-footer border-0 p-3 pt-0 justify-content-center">
                <button type="button" class="btn btn-light px-4 border" data-bs-dismiss="modal">Hủy bỏ</button>
                <button type="button" class="btn btn-primary px-5 fw-bold shadow-sm" onclick="executeConfirmedAction()">Xác nhận</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editInventoryModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <form asp-action="UpdateInventory" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="productId" id="editInvProductId">
                <input type="hidden" name="locationId" id="editInvLocationId">
                <div class="modal-header bg-dark text-white border-0">
                    <h5 class="modal-title fw-bold">Điều chỉnh tồn kho</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-2 small text-muted text-uppercase fw-bold">Sản phẩm điều chỉnh</div>
                    <h6 class="fw-bold mb-4 p-2 bg-light border rounded" id="editInvProductName">...</h6>
                    <div>
                        <label class="form-label small fw-bold">Số lượng khả dụng mới *</label>
                        <input type="number" name="quantity" id="editInvQuantity" class="form-control form-control-lg border-primary shadow-sm" required min="0">
                        <small class="text-muted mt-1 d-block">Lưu ý: Thay đổi này sẽ ảnh hưởng trực tiếp đến dữ liệu bán hàng.</small>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold shadow">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="createQCModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <form asp-action="CreateQCRecord" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header bg-info text-white border-0 p-4">
                    <h5 class="modal-title fw-bold"><i class="bi bi-shield-check me-2"></i>Lập phiếu kiểm định chất lượng (QC)</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4 bg-light">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-uppercase">Sản phẩm cần kiểm định *</label>
                            <select name="productId" class="form-select border-0 shadow-sm" required>
                                <option value="">-- Chọn sản phẩm --</option>
                                @foreach (var p in Model.AllProducts) {
                                    <option value="@p.ProductID">@p.ProductName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-uppercase">Mã tham chiếu (PO/SO/RTN) *</label>
                            <input type="text" name="referenceId" class="form-control border-0 shadow-sm" required placeholder="Ví dụ: PO-00001">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-uppercase">Kết quả đánh giá</label>
                            <div class="d-flex gap-4 mt-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="result" value="Đạt" checked id="qcOk">
                                    <label class="form-check-label fw-bold text-success" for="qcOk">Đạt tiêu chuẩn</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="result" value="Không đạt" id="qcFail">
                                    <label class="form-check-label fw-bold text-danger" for="qcFail">Lỗi/Không đạt</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold text-uppercase">Ghi chú chi tiết</label>
                            <textarea name="notes" class="form-control border-0 shadow-sm" rows="3" placeholder="Mô tả tình trạng hàng hóa..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer p-4 border-0 bg-white">
                    <button type="button" class="btn btn-light px-4 border" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-info text-white px-5 fw-bold shadow-sm">Lưu phiếu QC</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="addLocationModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered text-start">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <form asp-action="AddLocation" method="post">
                <div class="modal-header bg-success text-white border-0 p-4">
                    <h5 class="modal-title fw-bold"><i class="bi bi-plus-square me-2"></i>Thêm Vị trí lưu kho mới</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4 bg-light">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Mã vị trí (VD: A-01-01) *</label>
                            <input type="text" name="code" class="form-control border-0 shadow-sm" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Sức chứa tối đa (Thùng/SP) *</label>
                            <input type="number" name="capacity" class="form-control border-0 shadow-sm" value="100" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold">Loại khu vực</label>
                            <select name="type" class="form-select border-0 shadow-sm">
                                <option>Thông thường</option>
                                <option>Yêu cầu nhiệt độ</option>
                                <option>Hàng giá trị cao</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer p-4 border-0">
                    <button type="submit" class="btn btn-success w-100 rounded-pill py-2 fw-bold shadow">Tạo vị trí</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>

<script>
    function GenQRCode (){
        var deliveryId = document.getElementById("pickupSelect").value;
        
        if (!deliveryId) {
            alert("Vui lòng chọn một đơn hàng để tạo mã!");
            return;
        }

        var currentDomain = window.location.origin;
        var scanUrl = currentDomain + "/Delivery/ScanPickup?deliveryId=" + deliveryId;

        document.getElementById("qrcodeCanvas").innerHTML = "";

        new QRCode(document.getElementById("qrcodeCanvas"), {
            text: scanUrl,          
            width: 180,              
            height: 180,            
            colorDark : "#000000",   
            colorLight : "#ffffff",  
            correctLevel : QRCode.CorrectLevel.H 
        });

        document.getElementById("qrDisplay").classList.remove("d-none");
    }
</script>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            function forceSwitchTab() {
                let hash = window.location.hash;

                if(!hash){
                    let urlParams = new URLSearchParams(window.location.search);
                    hash = urlParams.get('hash');
                    if(hash){history.replaceState(null, null, window.location.pathname+ window.location.search+hash);}
                }

                hash = hash || "#menu1";

                let tabLink = document.querySelector('.nav-tabs a[href="' + hash + '"]');
                
                if (tabLink) {
                    let tab = new bootstrap.Tab(tabLink);
                    tab.show();
                }
            }

            forceSwitchTab();
            window.addEventListener('hashchange', function() {
                forceSwitchTab();
            });

            let tabs = document.querySelectorAll('.nav-tabs a[data-bs-toggle="tab"]');
            tabs.forEach(tab => {
                tab.addEventListener('shown.bs.tab', function (e) {
                    let targetHash = tab.getAttribute('href');
                
                    if (window.location.hash !== targetHash) {
                        history.pushState(null, null, targetHash);
                        
                        window.dispatchEvent(new Event('hashchange')); 
                    }
                });
            });
        });



        let currentConfirmAction = null;

        function showInboundConfirm(id) { 
            currentConfirmAction = () => { 
                let f = document.createElement('form'); 
                f.method='POST'; 
                f.action='/Storage/ProcessReceipt'; 
                let i = document.createElement('input'); 
                i.name='poid'; 
                i.value=id; 
                f.appendChild(i); 
                let t = document.querySelector('input[name="__RequestVerificationToken"]').cloneNode(); 
                f.appendChild(t); 
                document.body.appendChild(f); 
                f.submit(); 
            };
            document.getElementById('confirmActionTitle').innerText = "Xử lý nhập kho";
            document.getElementById('confirmActionBody').innerText = "Bạn xác nhận nhập đơn hàng PO-" + id.toString().padStart(5,'0') + " vào kho ?";
            new bootstrap.Modal(document.getElementById('confirmActionModal')).show();
        }

        function showPickingConfirm(id) {
            currentConfirmAction = () => { 
                $.ajax({ 
                    url: '/Storage/MarkAsPicked', 
                    type: 'POST', 
                    data: { soid: id }, 
                    headers: { "RequestVerificationToken": document.querySelector('input[name="__RequestVerificationToken"]').value }, 
                    success: () => { 
                        window.location.hash="#menu5"; 
                        location.reload(); 
                    } 
                });
            };
            document.getElementById('confirmActionTitle').innerText = "Hoàn tất soạn hàng";
            document.getElementById('confirmActionBody').innerText = "Xác nhận đã soạn đủ hàng cho đơn SO-" + id.toString().padStart(5,'0') + ". Chuyển sang trạng thái chờ bàn giao ?";
            new bootstrap.Modal(document.getElementById('confirmActionModal')).show();
        }

        function executeConfirmedAction() { 
            if(currentConfirmAction) currentConfirmAction(); 
        }

        function showEditInventory(pid, lid, name, qty) {
            document.getElementById('editInvProductId').value = pid;
            document.getElementById('editInvLocationId').value = lid;
            document.getElementById('editInvProductName').innerText = name;
            document.getElementById('editInvQuantity').value = qty;
            new bootstrap.Modal(document.getElementById('editInventoryModal')).show();
        }

        const conn = new signalR.HubConnectionBuilder().withURL("/HandoverHub").build();

        conn.on("OrderHandOver", function(deliveryId){

            const selectElement = document.getElementById("pickupSelect");
            const optionToRemove = selectElement.querySelector(`option[value='${deliveryId}']`);
        
            if(optionToRemove) {
                const orderName = optionToRemove.text;
                optionToRemove.remove(); 

                alert("Thông báo: Đơn hàng [" + orderName + "] đã được Shipper quét nhận thành công!");
                
                document.getElementById("qrDisplay").classList.add("d-none");
            }

        });
    </script>
}
