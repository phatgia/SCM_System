                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>

                                    <div class="modal-body p-4">
                                        <form id="addLocationForm">
                                            <div class="row g-3">
                                                <div class="col-md-6">
                                                    <label for="locationCode" class="form-label fw-medium text-secondary small">Mã vị trí <span class="text-danger">*</span></label>
                                                    <input type="text" class="form-control" id="locationCode" placeholder="VD: F1" required>
                                                </div>
                                                <div class="col-md-6">
                                                    <label for="capacity" class="form-label fw-medium text-secondary small">Sức chứa tối đa <span class="text-danger">*</span></label>
