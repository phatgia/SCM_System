@using Microsoft.AspNetCore.Http.Features
@model SCM_System.Models.ViewModels.DeliveryViewModel
@{ViewData["Title"] = "Vận chuyển";}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div><h4 class="fw-bold mb-1">Vận chuyển & Giao nhận</h4><p class="text-muted small mb-0">Điều phối, theo dõi và xác nhận bàn giao hàng hóa</p></div>
</div>
<ul class="nav nav-tabs mb-4">
    <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#menu1"><i class="bi bi-card-list me-1"></i>Danh sách giao hàng</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#menu2"><i class="bi bi-qr-code me-1"></i>Bàn giao Handshake</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#menu3"><i class="bi bi-clock-history me-1"></i>Cập nhật trạng thái</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#menu4"><i class="bi bi-arrow-return-left me-1"></i>Ghi nhận trả hàng</a>
</li>
</ul>
<div class="tab-content">
    <!-- DANH SÁCH GIAO HÀNG -->
    <div class="tab-pane active" id="menu1">
        <div class="row g-3 mb-3">
            <div class="col-md-4"><div class="card border-0 shadow-sm text-center p-3"><div class="fs-2 fw-bold text-warning">@Model.PendingPickupCount</div><div class="small text-muted">Chờ lấy hàng</div></div></div>
            <div class="col-md-4"><div class="card border-0 shadow-sm text-center p-3"><div class="fs-2 fw-bold text-primary">@Model.InDeliveryCount</div><div class="small text-muted">Đang giao</div></div></div>
            <div class="col-md-4"><div class="card border-0 shadow-sm text-center p-3"><div class="fs-2 fw-bold text-success">@Model.CompletedThisMonthCount</div><div class="small text-muted">Hoàn thành tháng <span class="text-success fw-bold">@DateTime.Now.Month</span> này</div></div></div>
        </div>
        
        <div class="card border-0 shadow-sm mb-4 d-md-none">
            <div class="card-body bg-light rounded text-center">
                <h6 class="fw-bold text-primary mb-3">Nhận hàng từ Kho (Handshake 1)</h6>
                <p class="small text-muted mb-3">Đưa camera quét mã QR trên màn hình của Thủ kho để xác nhận nhận hàng đi giao.</p>
                
                <button class="btn btn-warning fw-bold px-4 rounded-pill shadow" id="btnStartScan" onclick="startQRScanner()">
                    <i class="bi bi-upc-scan me-2"></i>Bật Camera Quét Mã
                </button>

                <button class="btn btn-outline-danger fw-bold px-4 rounded-pill shadow d-none mt-2" id="btnStopScan" onclick="stopQRScanner()">
                    <i class="bi bi-x-circle me-2"></i>Đóng Camera
                </button>

                <div id="reader" class="mt-3 mx-auto" style="width: 100%; max-width: 400px; border-radius: 10px; overflow: hidden; display: none;"></div>
            </div>
        </div>

        <div class="card border-0 shadow-sm"><div class="card-body p-0"><div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light"><tr><th class="ps-4 py-2 small text-white border-0">MÃ ĐƠN</th><th class="py-2 small text-white border-0">KHÁCH HÀNG</th><th class="py-2 small text-white border-0">SHIPPER</th><th class="py-2 small text-white border-0">ĐỊA CHỈ GIAO</th><th class="py-2 small text-white border-0">COD</th><th class="py-2 small text-white border-0">TRẠNG THÁI</th><th class="py-2 small text-white border-0">Thời gian</th></tr></thead>
                <tbody>
                    @foreach(var item in Model.AllDeliveries){
                        <tr>
                            <td class="ps-4 py-2 fw-semibold small text-primary">@item.OrderCode</td>
                            <td class="py-2"><div class="small fw-semibold">@item.CustomerName</div><div class="small text-muted">@item.CustomerPhone</div></td>
                            <td class="py-2 small">@item.ShipperName</td><td class="py-2 small text-muted">@item.Address</td>
                            <td class="py-2 small fw-semibold">@item.TotalAmount</td>
                            <td class="py-2">
                                @if(item.Status == "Thành công"){
                                    <span class="badge bg-success bg-opacity-10 text-success px-2">Hoàn thành</span>
                                }else if(item.Status == "Đang giao hàng"){
                                    <span class="badge bg-primary bg-opacity-10 text-primary px-2">Đang giao hàng</span>
                                }else if(item.Status == "Chờ lấy hàng"){
                                    <span class="badge bg-danger bg-opacity-10 text-danger px-2">Chờ lấy hàng</span>
                                }
                                else{
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary px-2">@item.Status</span>
                                }
                                
                            </td>
                            <td class="py-2">@item.DeliveryTime</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div></div></div>
    </div>

    <!-- HANDSHAKE -->
    <div class="tab-pane" id="menu2">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm"><div class="card-header bg-white border-0 pt-3 pb-0 px-4"><h6 class="fw-bold mb-0"><i class="bi bi-person-check me-1 text-success"></i>Bàn giao cho khách (Handshake 2)</h6></div><div class="card-body">
                    <p class="small text-muted mb-3">Shipper xác nhận giao hàng thành công bằng ảnh chữ ký / ảnh gói hàng.</p>
                    <div class="mb-3"><label class="form-label small fw-semibold">Mã đơn hàng</label><input type="text" class="form-control" placeholder="Nhập mã đơn đang giao..."></div>
                    <div class="mb-3"><label class="form-label small fw-semibold">Kết quả giao hàng</label>
                        <div class="d-flex gap-3">
                            <div class="form-check"><input class="form-check-input" type="radio" name="delivResult" id="r1" checked><label class="form-check-label small" for="r1">Giao thành công</label></div>
                            <div class="form-check"><input class="form-check-input" type="radio" name="delivResult" id="r2"><label class="form-check-label small" for="r2">Khách từ chối</label></div>
                        </div>
                    </div>
                    <div class="mb-3"><label class="form-label small fw-semibold">Ảnh minh chứng *</label><input type="file" class="form-control form-control-sm" accept="image/*"></div>
                    <button class="btn btn-success w-100"><i class="bi bi-check2-circle me-1"></i>Hoàn tất bàn giao</button>
                </div></div>
            </div>
        </div>
    </div>

    <!-- CẬP NHẬT TRẠNG THÁI -->
    <div class="tab-pane" id="menu3">
        <div class="card border-0 shadow-sm mb-3"><div class="card-body p-3">
            <div class="row g-3 align-items-end">
                <div class="col-md-5"><label class="form-label small fw-semibold">Tìm đơn hàng</label><div class="input-group"><input type="text" class="form-control" placeholder="Mã đơn hàng..."><button class="btn btn-primary"><i class="bi bi-search"></i></button></div></div>
            </div>
        </div></div>
        <div class="card border-0 shadow-sm"><div class="card-header bg-white border-0 pt-3 pb-0 px-4"><h6 class="fw-bold mb-0">Timeline — SO-2026-040</h6></div><div class="card-body">
            <div class="d-flex flex-column gap-3">
                <div class="d-flex align-items-start gap-3"><div class="rounded-circle bg-success d-flex align-items-center justify-content-center flex-shrink-0" style="width:32px;height:32px;"><i class="bi bi-check text-white small"></i></div><div><p class="mb-0 small fw-semibold">Lấy hàng từ kho</p><p class="mb-0 small text-muted">19/04/2026 10:00 — Shipper: Trần Văn Cường</p></div></div>
                <div class="d-flex align-items-start gap-3"><div class="rounded-circle bg-warning d-flex align-items-center justify-content-center flex-shrink-0" style="width:32px;height:32px;"><i class="bi bi-truck text-white small"></i></div><div><p class="mb-0 small fw-semibold">Đang di chuyển đến khách</p><p class="mb-0 small text-muted">19/04/2026 10:45</p></div></div>
                <div class="d-flex align-items-start gap-3"><div class="rounded-circle bg-light border d-flex align-items-center justify-content-center flex-shrink-0" style="width:32px;height:32px;"><i class="bi bi-house text-muted small"></i></div><div class="text-muted"><p class="mb-0 small fw-semibold">Giao cho khách</p><p class="mb-0 small">Chờ xác nhận...</p></div></div>
            </div>
            <hr>
            <div class="row g-3">
                <div class="col-md-5"><label class="form-label small fw-semibold">Cập nhật trạng thái mới</label><select class="form-select"><option>Đang di chuyển đến khách</option><option>Khách hẹn giao lại</option><option>Không liên lạc được khách</option></select></div>
                <div class="col-md-5"><label class="form-label small fw-semibold">Ghi chú</label><input type="text" class="form-control" placeholder="Ghi chú thêm..."></div>
                <div class="col-auto d-flex align-items-end"><button class="btn btn-primary">Lưu cập nhật</button></div>
            </div>
        </div></div>
    </div>
    <!-- TAB: Ghi nhận trả hàng -->
    <div class="tab-pane" id="menu4">

        <!-- Thông báo -->
        <div class="alert alert-danger small">
            Ghi nhận trường hợp giao hàng không thành công để hoàn trả hàng về kho.
        </div>

        <!-- BUTTON giống ảnh 1 -->
        <button class="btn btn-danger mb-3"
                onclick="showReturnForm()">
            + Ghi nhận trả hàng tại chỗ
        </button>

        <!-- FORM (ẩn ban đầu) -->
        <div id="returnFormBox" class="card border-0 shadow-sm d-none" style="max-width:420px">
            <div class="card-body">

                <h6 class="fw-bold mb-3">Ghi nhận trả hàng</h6>

                <form asp-action="RecordReturn" method="post">
                    @Html.AntiForgeryToken()

                    <!-- Đơn hàng -->
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Đơn hàng</label>
                        <select name="soid" class="form-select">
                        </select>
                    </div>

                    <!-- Lý do -->
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Lý do không giao được</label>

                        <div class="d-flex flex-column gap-2">

                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="reason"
                                    value="Khách không có mặt" checked>
                                <label class="form-check-label small">
                                    Khách hàng không có mặt tại địa chỉ
                                </label>
                            </div>

                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="reason"
                                    value="Sai địa chỉ">
                                <label class="form-check-label small">
                                    Địa chỉ không tồn tại / không tìm thấy
                                </label>
                            </div>

                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="reason"
                                    value="Khách từ chối">
                                <label class="form-check-label small">
                                    Khách hàng từ chối nhận hàng
                                </label>
                            </div>

                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="reason"
                                    value="Hàng hỏng">
                                <label class="form-check-label small">
                                    Hàng hóa bị hư hỏng trong quá trình vận chuyển
                                </label>
                            </div>

                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="reason"
                                    value="Sai sản phẩm">
                                <label class="form-check-label small">
                                    Sai sản phẩm / số lượng
                                </label>
                            </div>

                        </div>
                    </div>

                    <!-- Ghi chú -->
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Ghi chú thêm</label>
                        <textarea name="settlement" class="form-control"
                                placeholder="Mô tả chi tiết..."></textarea>
                    </div>

                    <!-- Button -->
                    <div class="d-flex justify-content-between">
                        <button type="button" class="btn btn-light"
                                onclick="hideReturnForm()">
                            Hủy
                        </button>

                        <button type="submit" class="btn btn-danger">
                            Ghi nhận trả hàng
                        </button>
                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

<!-- Modal Phân công -->
<div class="modal fade" id="modalPhanCong" tabindex="-1"><div class="modal-dialog modal-dialog-centered"><div class="modal-content border-0 shadow">
    <div class="modal-header border-0"><h5 class="modal-title fw-bold">Phân công vận chuyển</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
        <p class="small text-muted mb-3">Đơn hàng đã chọn: <strong>SO-2026-039</strong></p>
        <div class="mb-3"><label class="form-label small fw-semibold">Nhân viên vận chuyển *</label>
            <select class="form-select">
                <option>-- Chọn nhân viên --</option>
                <option>Trần Văn Cường (Đang rảnh)</option>
                <option>Nguyễn Hữu Lộc (Đang rảnh)</option>
                <option>Lê Quang Vinh (Đang bận — 2 đơn)</option>
            </select>
        </div>
        <div class="mb-3"><label class="form-label small fw-semibold">Ghi chú lộ trình</label><textarea class="form-control" rows="2" placeholder="Ghi chú đặc biệt cho shipper..."></textarea></div>
    </div>
    <div class="modal-footer border-0"><button class="btn btn-light border" data-bs-dismiss="modal">Hủy</button><button class="btn btn-primary"><i class="bi bi-check2 me-1"></i>Phân công</button></div>
</div></div></div>

<script src="https://unpkg.com/html5-qrcode"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
    function showReturnForm() {
        document.getElementById("returnFormBox").classList.remove("d-none");
    }

    function hideReturnForm() {
        document.getElementById("returnFormBox").classList.add("d-none");
    }

    document.addEventListener("DOMContentLoaded", function () {
        function forceSwitchTab() {
            let hash = window.location.hash || "#menu1";
            let tabLink = document.querySelector('.nav-tabs a[href="' + hash + '"]');
            
            if (tabLink) {
                let tab = new bootstrap.Tab(tabLink);
                tab.show();
            }
        }

       
        forceSwitchTab();

        window.addEventListener('hashchange', forceSwitchTab);

    
        let tabElements = document.querySelectorAll('.nav-tabs a[data-bs-toggle="tab"]');
        tabElements.forEach(function(el) {
            el.addEventListener('shown.bs.tab', function (e) {
                let currentHash = e.target.getAttribute('href');

                history.replaceState(null, null, currentHash); 
                
                window.dispatchEvent(new Event('hashchange')); 
            });
        });
    });

    function GenQRCode (){
        var deliveryId = document.getElementById("pickupSelect").value;
        
        if (!deliveryId) {
            alert("Vui lòng chọn một đơn hàng để tạo mã!");
            return;
        }

        var currentDomain = window.location.origin;
        var scanUrl = currentDomain + "/Delivery/ScanPickup?deliveryId=" + deliveryId;

        document.getElementById("qrcodeCanvas").innerHTML = "";

        new QRCode(document.getElementById("qrcodeCanvas"), {
            text: scanUrl,          
            width: 180,              
            height: 180,            
            colorDark : "#000000",   
            colorLight : "#ffffff",  
            correctLevel : QRCode.CorrectLevel.H 
        });

        document.getElementById("qrDisplay").classList.remove("d-none");
    }


    let html5QrCode;

    function startQRScanner() {
        document.getElementById('reader').style.display = 'block';
        document.getElementById('btnStartScan').classList.add('d-none');
        document.getElementById('btnStopScan').classList.remove('d-none');

        html5QrCode = new Html5Qrcode("reader");

        const config = { fps: 10, qrbox: { width: 250, height: 250 } };

        const onScanSuccess = (decodedText, decodedResult) => {
            stopQRScanner();
            window.location.href = decodedText;
        };

        html5QrCode.start({ facingMode: "environment" }, config, onScanSuccess)
        .catch(err => {
            alert("Lỗi mở Camera: Hãy đảm bảo bạn đã cấp quyền sử dụng máy ảnh cho trình duyệt web!");
            stopQRScanner();
        });
    }

    function stopQRScanner() {
        if (html5QrCode) {
            html5QrCode.stop().then(() => {
                document.getElementById('reader').style.display = 'none';
                document.getElementById('btnStartScan').classList.remove('d-none');
                document.getElementById('btnStopScan').classList.add('d-none');
            }).catch(err => {
                console.log("Lỗi khi tắt camera", err);
            });
        }
    }
</script>