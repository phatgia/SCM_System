@using Microsoft.AspNetCore.Http.Features
@model SCM_System.Models.ViewModels.DeliveryViewModel
@{ViewData["Title"] = "Vận chuyển";}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 fw-bold mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2 text-success"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div><h4 class="fw-bold mb-1">Vận chuyển & Giao nhận</h4><p class="text-muted small mb-0">Điều phối, theo dõi và xác nhận bàn giao hàng hóa</p></div>
</div>
<ul class="nav nav-tabs mb-4">
    <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#menu1"><i class="bi bi-card-list me-1"></i>Danh sách giao hàng</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#menu2"><i class="bi bi-qr-code me-1"></i>Bàn giao Handshake</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#menu3"><i class="bi bi-clock-history me-1"></i>Cập nhật trạng thái</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#menu4"><i class="bi bi-arrow-return-left me-1"></i>Ghi nhận trả hàng</a>
</li>
</ul>
<div class="tab-content">
    <!-- DANH SÁCH GIAO HÀNG -->
    <div class="tab-pane active" id="menu1">
        <div class="row g-3 mb-3">
            <div class="col-md-4"><div class="card border-0 shadow-sm text-center p-3"><div class="fs-2 fw-bold text-warning">@Model.PendingPickupCount</div><div class="small text-muted">Chờ lấy hàng</div></div></div>
            <div class="col-md-4"><div class="card border-0 shadow-sm text-center p-3"><div class="fs-2 fw-bold text-primary">@Model.InDeliveryCount</div><div class="small text-muted">Đang giao</div></div></div>
            <div class="col-md-4"><div class="card border-0 shadow-sm text-center p-3"><div class="fs-2 fw-bold text-success">@Model.CompletedThisMonthCount</div><div class="small text-muted">Hoàn thành tháng <span class="text-success fw-bold">@DateTime.Now.Month</span> này</div></div></div>
        </div>
        
        <div class="card border-0 shadow-sm mb-4 d-md-none">
            <div class="card-body bg-light rounded text-center">
                <h6 class="fw-bold text-primary mb-3">
                    <i class="bi bi-upc-scan me-2"></i>Nhận hàng từ Kho
                </h6>
                
                <button class="btn btn-warning fw-bold px-4 rounded-pill shadow" data-bs-toggle="modal" data-bs-target="#qrScannerModal">
                    <i class="bi bi-upc-scan me-2"></i>Bật Camera Quét Mã
                </button>
            </div>
        </div>

        <div class="card border-0 shadow-sm"><div class="card-body p-0"><div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light"><tr><th class="ps-4 py-2 small text-white border-0">MÃ ĐƠN</th><th class="py-2 small text-white border-0">KHÁCH HÀNG</th><th class="py-2 small text-white border-0">SHIPPER</th><th class="py-2 small text-white border-0">ĐỊA CHỈ GIAO</th><th class="py-2 small text-white border-0">COD</th><th class="py-2 small text-white border-0">TRẠNG THÁI</th><th class="py-2 small text-white border-0">Thời gian</th></tr></thead>
                <tbody>
                    @foreach(var item in Model.AllDeliveries){
                        <tr>
                            <td class="ps-4 py-2 fw-semibold small text-primary">@item.OrderCode</td>
                            <td class="py-2"><div class="small fw-semibold">@item.CustomerName</div><div class="small text-muted">@item.CustomerPhone</div></td>
                            <td class="py-2 small">@item.ShipperName</td><td class="py-2 small text-muted">@item.Address</td>
                            <td class="py-2 small fw-semibold">@item.TotalAmount</td>
                            <td class="py-2">
                                @if(item.Status == "Hoàn thành" || item.Status == "Thành công" || item.Status == "Giao thành công"){
                                    <span class="badge bg-success bg-opacity-10 text-success px-2">@item.Status</span>
                                }
                                else if(item.Status == "Đang giao hàng" || item.Status == "Đang giao"){
                                    <span class="badge bg-primary bg-opacity-10 text-primary px-2">@item.Status</span>
                                }
                                else if(item.Status == "Chờ lấy hàng"){
                                    <span class="badge bg-warning bg-opacity-10 text-warning px-2">@item.Status</span>
                                }
                                else{
                                    <span class="badge bg-danger bg-opacity-10 text-danger px-2">@item.Status</span>
                                }
                            </td>
                            <td class="py-2">@item.DeliveryTime</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div></div></div>
    </div>

    <!-- HANDSHAKE -->
    <div class="tab-pane" id="menu2">
        <div class="row g-4">
            <div class="col-md-6">
                <form asp-action="CompleteDelivery" asp-controller="Delivery" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Chọn đơn hàng đang giao</label>
                        <select class="form-select" name="deliveryId" required>
                            <option value="">-- Chọn đơn hàng đang giao --</option>
                            @foreach(var item in Model.AllDeliveries.Where(d => d.Status == "Đang giao hàng"))
                            {
                                <option value="@item.DeliveryID">@item.OrderCode - @item.CustomerName</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Kết quả giao hàng</label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="result" value="Giao thành công" id="r1" checked>
                                <label class="form-check-label small" for="r1">Giao thành công</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="result" value="Khách từ chối" id="r2">
                                <label class="form-check-label small" for="r2">Khách từ chối</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Ảnh minh chứng *</label>
                        <input type="file" name="proofImage" class="form-control form-control-sm" accept="image/*" required>
                    </div>

                    <button type="submit" class="btn btn-success w-100">
                        <i class="bi bi-check2-circle me-1"></i>Hoàn tất bàn giao
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- CẬP NHẬT TRẠNG THÁI -->
    <div class="tab-pane" id="menu3">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body p-3">
                <form asp-action="SearchDeliveryTimeline" asp-controller="Delivery" method="get">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-6"> <label class="form-label small fw-semibold">Chọn đơn hàng để cập nhật trạng thái</label>
                            <div class="input-group">
                                <select class="form-select" name="orderCode" required>
                                    <option value="" disabled selected>-- Chọn đơn hàng đang giao --</option>
                                    @foreach(var item in Model.AllDeliveries.Where(d => d.Status == "Đang giao hàng"))
                                    {
                                        if(Context.Request.Query["searchCode"] == item.OrderCode)
                                        {
                                            <option value="@item.OrderCode" selected>@item.OrderCode - Khách: @item.CustomerName</option>
                                        }
                                        else
                                        {
                                            <option value="@item.OrderCode">@item.OrderCode - Khách: @item.CustomerName</option>
                                        }
                                    }
                                </select>
                                
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-search"></i> Xem lịch sử
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        @if (ViewBag.SearchedDelivery is SCM_System.Models.Delivery delivery)
        {
            string orderCodeStr = $"SO-{DateTime.Now.Year}-{delivery.SOID:D3}";
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-3 pb-0 px-4">
                    <h6 class="fw-bold mb-0">Timeline — @orderCodeStr</h6>
                </div>
                <div class="card-body">
                    
                    <div class="d-flex flex-column gap-3 mb-4">
                        @if (delivery.DeliveryTrackings != null && delivery.DeliveryTrackings.Any())
                        {
                            foreach (var tracking in delivery.DeliveryTrackings.OrderBy(t => t.EventTime))
                            {
                                <div class="d-flex align-items-start gap-3">
                                    <div class="rounded-circle bg-success d-flex align-items-center justify-content-center flex-shrink-0" style="width:32px;height:32px;">
                                        <i class="bi bi-check text-white small"></i>
                                    </div>
                                    <div>
                                        <p class="mb-0 small fw-semibold">@tracking.StatusEvent</p>
                                        <p class="mb-0 small text-muted">@tracking.EventTime.ToString("dd/MM/yyyy HH:mm") — Shipper: @tracking.ShipperName</p>
                                        @if (!string.IsNullOrEmpty(tracking.Note))
                                        {
                                            <p class="mb-0 small text-dark fst-italic">Ghi chú: @tracking.Note</p>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted small fst-italic">Chưa có lịch sử cập nhật nào cho đơn hàng này.</p>
                        }
                    </div>

                    <hr>

                    <form asp-action="AddTrackingEvent" asp-controller="Delivery" method="post">
                        <input type="hidden" name="deliveryId" value="@delivery.DeliveryID" />
                        
                        <div class="row g-3">
                            <div class="col-md-5">
                                <label class="form-label small fw-semibold">Cập nhật trạng thái mới</label>
                                <select name="statusEvent" class="form-select" required>
                                    <option value="Đang di chuyển đến khách">Đang di chuyển đến khách</option>
                                    <option value="Khách hẹn giao lại">Khách hẹn giao lại</option>
                                    <option value="Không liên lạc được khách">Không liên lạc được khách</option>
                                    <option value="Sự cố đi đường">Sự cố đi đường</option>
                                </select>
                            </div>
                            <div class="col-md-5">
                                <label class="form-label small fw-semibold">Ghi chú</label>
                                <input type="text" name="note" class="form-control" placeholder="Ghi chú thêm...">
                            </div>
                            <div class="col-auto d-flex align-items-end">
                                <button type="submit" class="btn btn-primary">Lưu cập nhật</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        }
    </div>
    <!-- TAB: Ghi nhận trả hàng -->
    <div class="tab-pane" id="menu4">
        <div class="alert alert-danger mb-4 border-0 shadow-sm">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> Ghi nhận trường hợp giao hàng không thành công để hoàn trả hàng về kho.
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="RecordReturn" asp-controller="Delivery" method="post">
                    <div class="row g-4">
                        
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small">Mã đơn hàng</label>
                            <input type="text" name="orderCode" class="form-control" placeholder="VD: SO-2026-039" value="@Context.Request.Query["searchCode"]" required>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-semibold small">Lý do hoàn trả</label>
                            <select name="reason" class="form-select" required>
                                <option value="" disabled selected>-- Chọn lý do --</option>
                                <option value="Khách hàng từ chối nhận">Khách hàng từ chối nhận</option>
                                <option value="Không liên lạc được khách (Quá 3 lần)">Không liên lạc được khách (Quá 3 lần)</option>
                                <option value="Hàng hóa bị hỏng/lỗi khi vận chuyển">Hàng hóa hỏng/lỗi khi vận chuyển</option>
                                <option value="Sai thông tin đơn hàng">Sai thông tin đơn hàng</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-semibold small">Hướng xử lý (Settlement)</label>
                            <select name="settlement" class="form-select" required>
                                <option value="" disabled selected>-- Chọn hướng xử lý --</option>
                                <option value="Nhập lại kho, chờ xử lý">Nhập lại kho, chờ kiểm tra</option>
                                <option value="Hoàn tiền cho khách">Hoàn tiền cho khách</option>
                                <option value="Đổi trả sản phẩm khác">Đổi trả sản phẩm khác</option>
                                <option value="Tiêu hủy (Hàng hỏng nặng)">Tiêu hủy (Hàng hỏng nặng)</option>
                            </select>
                        </div>
                    </div>

                    <div class="mt-4 text-end">
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-box-arrow-in-down-left me-1"></i> Xác nhận hoàn hàng
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal Phân công -->
<div class="modal fade" id="modalPhanCong" tabindex="-1"><div class="modal-dialog modal-dialog-centered"><div class="modal-content border-0 shadow">
    <div class="modal-header border-0"><h5 class="modal-title fw-bold">Phân công vận chuyển</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
        <p class="small text-muted mb-3">Đơn hàng đã chọn: <strong>SO-2026-039</strong></p>
        <div class="mb-3"><label class="form-label small fw-semibold">Nhân viên vận chuyển *</label>
            <select class="form-select">
                <option>-- Chọn nhân viên --</option>
                <option>Trần Văn Cường (Đang rảnh)</option>
                <option>Nguyễn Hữu Lộc (Đang rảnh)</option>
                <option>Lê Quang Vinh (Đang bận — 2 đơn)</option>
            </select>
        </div>
        <div class="mb-3"><label class="form-label small fw-semibold">Ghi chú lộ trình</label><textarea class="form-control" rows="2" placeholder="Ghi chú đặc biệt cho shipper..."></textarea></div>
    </div>
    <div class="modal-footer border-0"><button class="btn btn-light border" data-bs-dismiss="modal">Hủy</button><button class="btn btn-primary"><i class="bi bi-check2 me-1"></i>Phân công</button></div>
</div></div></div>

@* Modeal Camera *@
<div class="modal fade" id="qrScannerModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header border-0 p-3">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-camera-video me-2"></i>Quét mã QR</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <div class="modal-body p-4 bg-dark text-center">
                <p class="small text-white-50 mb-3">Đưa mã QR của Thủ kho vào giữa khung hình</p>
                
                <div id="reader" class="mx-auto bg-black" style="width: 100%; max-width: 400px; border-radius: 10px; overflow: hidden; min-height: 250px;"></div>
            </div>
            
            <div class="modal-footer border-0 p-3 bg-light justify-content-center">
                <button type="button" class="btn btn-secondary px-5 rounded-pill fw-bold shadow-sm" data-bs-dismiss="modal">Hủy bỏ</button>
            </div>
        </div>
    </div>
</div>

<script src="https://unpkg.com/html5-qrcode"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
    function showReturnForm() {
        document.getElementById("returnFormBox").classList.remove("d-none");
    }

    function hideReturnForm() {
        document.getElementById("returnFormBox").classList.add("d-none");
    }

    document.addEventListener("DOMContentLoaded", function () {
        function forceSwitchTab() {
            let hash = window.location.hash || "#menu1";
            let tabLink = document.querySelector('.nav-tabs a[href="' + hash + '"]');
            
            if (tabLink) {
                let tab = new bootstrap.Tab(tabLink);
                tab.show();
            }
        }

       
        forceSwitchTab();

        window.addEventListener('hashchange', forceSwitchTab);

    
        let tabElements = document.querySelectorAll('.nav-tabs a[data-bs-toggle="tab"]');
        tabElements.forEach(function(el) {
            el.addEventListener('shown.bs.tab', function (e) {
                let currentHash = e.target.getAttribute('href');

                history.replaceState(null, null, currentHash); 
                
                window.dispatchEvent(new Event('hashchange')); 
            });
        });
    });

    function GenQRCode (){
        var deliveryId = document.getElementById("pickupSelect").value;
        
        if (!deliveryId) {
            alert("Vui lòng chọn một đơn hàng để tạo mã!");
            return;
        }

        var currentDomain = window.location.origin;
        var scanUrl = currentDomain + "/Delivery/ScanPickup?deliveryId=" + deliveryId;

        document.getElementById("qrcodeCanvas").innerHTML = "";

        new QRCode(document.getElementById("qrcodeCanvas"), {
            text: scanUrl,          
            width: 180,              
            height: 180,            
            colorDark : "#000000",   
            colorLight : "#ffffff",  
            correctLevel : QRCode.CorrectLevel.H 
        });

        document.getElementById("qrDisplay").classList.remove("d-none");
    }


        let html5QrCode;
        let isScanned = false;

        document.getElementById('qrScannerModal').addEventListener('shown.bs.modal', function () {
            isScanned = false;

            html5QrCode = new Html5Qrcode("reader");
            const config =   { fps: 10, qrbox: { width: 250, height: 250 } };

            const onScanSuccess = (decodedText, decodedResult) => {
                
                if(isScanned){return;}
                isScanned= true;
                stopQRScanner();
                
                var myModalEl = document.getElementById('qrScannerModal');
                var modal = bootstrap.Modal.getInstance(myModalEl);
                modal.hide();

                window.location.href = decodedText;
            };

            html5QrCode.start({ facingMode: "environment" }, config, onScanSuccess)
            .catch(err => {
                html5QrCode.start({ facingMode: "user" }, config, onScanSuccess)
                .catch(err2 => {
                    alert("Lỗi: Không có quyền truy cập Máy ảnh!");
                    stopQRScanner();
                });
            });
        });

        document.getElementById('qrScannerModal').addEventListener('hidden.bs.modal', function () {
            stopQRScanner();
        });

        function stopQRScanner() {
            if (html5QrCode) {
                html5QrCode.stop().then(() => {
                    html5QrCode.clear(); 
                    html5QrCode = null;
                }).catch(err => console.log("Lỗi khi tắt camera: ", err));
            }
        }
</script>